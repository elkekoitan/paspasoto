{
  "name": "paspasoto",
  "version": "0.1.0",
  "private": true,
  "description": "PaspasOto.com - Aracına özel 3D havuzlu oto paspas e-ticaret platformu",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:web": "pnpm --filter web dev",
    "dev:cms": "pnpm --filter cms develop",
    "build": "pnpm --filter \"./apps/*\" build",
    "lint": "pnpm --filter \"./apps/*\" lint",
    "typecheck": "pnpm --filter \"./apps/*\" typecheck",
    "seed": "pnpm --filter cms seed",
    "process-images": "node scripts/process-images.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.0",
    "sharp": "^0.33",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "better-sqlite3",
      "bcryptjs"
    ]
  }
}
