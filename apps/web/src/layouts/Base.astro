---
import '../styles/globals.css'
import Header from '@components/layout/Header.astro'
import BrandStrip from '@components/layout/BrandStrip.astro'
import Footer from '@components/layout/Footer.astro'
import MobileBottomNav from '@components/layout/MobileBottomNav.astro'
import MobileStickyCart from '@components/layout/MobileStickyCart.tsx'
import CookieConsent from '@components/layout/CookieConsent.astro'

interface Props {
  title?: string
  description?: string
  ogImage?: string
  noindex?: boolean
  canonical?: string
}

const SITE_NAME = 'Carmat'
const DEFAULT_TITLE = 'Carmat — Aracına Özel 3D Havuzlu Oto Paspas'
const DEFAULT_DESCRIPTION =
  'Aracına özel kalıplanmış 3D havuzlu oto paspas. 10 paspas rengi, 18 kenarlık rengi, marka logo aksesuarı ve premium topukluk seçenekleri. Konya atölyemizden kapına.'
const SITE_URL = import.meta.env.PUBLIC_SITE_URL ?? 'http://localhost:4321'

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  ogImage = '/assets/og-default.jpg',
  noindex = false,
  canonical,
} = Astro.props

const pageTitle = title === DEFAULT_TITLE ? title : `${title} · ${SITE_NAME}`
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE_URL).toString()
const ogImageUrl = new URL(ogImage, SITE_URL).toString()
---

<!doctype html>
<html lang="tr" dir="ltr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0B0B0F" />
    <meta name="color-scheme" content="dark" />

    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="tr_TR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <slot name="head" />
  </head>
  <body class="grain pb-[calc(64px+env(safe-area-inset-bottom))] md:pb-0">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-[var(--color-primary)] focus:px-4 focus:py-2 focus:text-[var(--color-bg)]"
    >
      İçeriğe geç
    </a>

    {/* Mobile thin top bar — sadece logo + ortalı (md+ ekranlarda gizli) */}
    <header class="md:hidden sticky top-0 z-30 bg-[var(--color-bg)]/85 backdrop-blur-md border-b border-[var(--color-border)]/40">
      <div class="flex items-center justify-center h-12 px-4">
        <a href="/" class="flex items-center" aria-label="Carmat anasayfa">
          <img src="/logo.png" alt="Carmat" class="h-7 w-auto" />
        </a>
      </div>
    </header>

    <Header />
    <BrandStrip />
    <main id="main">
      <slot />
    </main>
    <div class="hidden md:block"><Footer /></div>

    <MobileBottomNav />
    <MobileStickyCart client:only="preact" />

    {/* Çerez bildirim banner'ı — admin sayfaları hariç */}
    {!Astro.url.pathname.startsWith('/admin') && <CookieConsent />}

    {/* PWA Install Smart Banner — tepeden kayan otomatik davet (admin sayfaları hariç) */}
    {!Astro.url.pathname.startsWith('/admin') && (
      <div
        id="pwaInstallBanner"
        class="hidden fixed top-0 left-0 right-0 z-[60] px-3 py-2.5 bg-gradient-to-r from-[var(--color-primary)] via-amber-400 to-[var(--color-primary)] text-[var(--color-bg)] shadow-xl shadow-amber-500/30 transform -translate-y-full transition-transform duration-500"
      >
        <div class="max-w-2xl mx-auto flex items-center gap-3">
          <span class="size-10 grid place-items-center rounded-xl bg-black/20 ring-1 ring-black/10 shrink-0">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14" />
            </svg>
          </span>
          <div class="flex-1 min-w-0">
            <div class="font-bold text-sm leading-tight">Carmat uygulamasını ana ekrana ekle</div>
            <div class="text-[11px] opacity-85 leading-tight mt-0.5 truncate">Hızlı erişim · Çevrimdışı çalışır · Bildirim alır</div>
          </div>
          <button id="pwaInstallBtn" type="button" class="px-3.5 py-2 rounded-xl bg-black hover:bg-black/85 text-white text-xs font-bold whitespace-nowrap shadow-md">
            Ekle
          </button>
          <button id="pwaInstallClose" type="button" aria-label="Kapat" class="size-8 grid place-items-center rounded-xl hover:bg-black/15 shrink-0">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12" /></svg>
          </button>
        </div>
      </div>
    )}

    {/* iOS install instructions modal */}
    {!Astro.url.pathname.startsWith('/admin') && (
      <div id="iosInstallModal" class="hidden fixed inset-0 z-50 grid place-items-end md:place-items-center bg-black/70 backdrop-blur-sm p-4">
        <div class="w-full md:max-w-sm rounded-t-2xl md:rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 p-5">
          <div class="flex items-start justify-between gap-3 mb-3">
            <div>
              <h3 class="font-display font-semibold">iPhone'a Yükle</h3>
              <p class="text-xs text-[var(--color-text-muted)] mt-0.5">Carmat'ı uygulamadan kullan</p>
            </div>
            <button id="iosInstallClose" type="button" aria-label="Kapat" class="size-7 grid place-items-center rounded-lg hover:bg-[var(--color-surface-2)]">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12" /></svg>
            </button>
          </div>
          <ol class="space-y-3 text-sm">
            <li class="flex items-start gap-3">
              <span class="size-7 grid place-items-center rounded-full bg-[var(--color-primary)] text-[var(--color-bg)] font-bold text-xs shrink-0">1</span>
              <div>
                Safari'de alttaki <span class="inline-flex items-center gap-1 mx-1 px-1.5 py-0.5 rounded bg-[var(--color-surface-2)] text-[var(--color-primary)] font-semibold"><svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12m0-12-4 4m4-4 4 4M5 21h14" /></svg> Paylaş</span> butonuna basın
              </div>
            </li>
            <li class="flex items-start gap-3">
              <span class="size-7 grid place-items-center rounded-full bg-[var(--color-primary)] text-[var(--color-bg)] font-bold text-xs shrink-0">2</span>
              <div>Açılan menüden <span class="font-semibold text-[var(--color-primary)]">"Ana Ekrana Ekle"</span> seçin</div>
            </li>
            <li class="flex items-start gap-3">
              <span class="size-7 grid place-items-center rounded-full bg-[var(--color-primary)] text-[var(--color-bg)] font-bold text-xs shrink-0">3</span>
              <div>Sağ üst köşedeki <span class="font-semibold text-[var(--color-primary)]">"Ekle"</span> butonuna basın</div>
            </li>
          </ol>
        </div>
      </div>
    )}

    {/* Floating WhatsApp 'Soru Sor' CTA — admin sayfaları hariç her yerde görünür */}
    {!Astro.url.pathname.startsWith('/admin') && (
      <a
        href="https://wa.me/905447108115?text=Merhaba%2C+aracıma+özel+paspas+hakkında+bir+sorum+var."
        target="_blank"
        rel="noopener"
        aria-label="WhatsApp ile soru sor"
        class="fixed right-4 md:right-5 bottom-[calc(72px+env(safe-area-inset-bottom))] md:bottom-5 z-40 group flex items-center gap-2.5 pl-3.5 pr-4 py-3 rounded-full shadow-2xl shadow-emerald-900/40 ring-1 ring-emerald-400/30 bg-gradient-to-br from-emerald-500 to-emerald-600 text-white hover:scale-[1.04] hover:shadow-emerald-700/40 transition-all"
      >
        <span class="size-5 grid place-items-center rounded-full bg-white/15">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
            <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.16 5.335 5.495 0 12.05 0c3.181 0 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414 0 6.557-5.336 11.892-11.893 11.892-1.99 0-3.951-.5-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
          </svg>
        </span>
        <span class="text-sm font-semibold whitespace-nowrap">Soru Sor</span>
        <span class="hidden md:inline-block px-1.5 py-0.5 rounded text-[9px] font-bold bg-white/20 leading-none ml-0.5">
          ATÖLYE
        </span>
      </a>
    )}

    <script>
      // Service Worker kaydı — PWA için şart (HTTPS gerektirir)
      if ('serviceWorker' in navigator && location.protocol === 'https:') {
        window.addEventListener('load', () => {
          navigator.serviceWorker
            .register('/sw.js', { scope: '/' })
            .catch((err) => console.warn('SW kayıt hatası:', err))
        })
      }

      // PWA install banner — tepeden kayar, otomatik açılır (1x dismiss edilirse 14 gün gizli)
      const banner = document.getElementById('pwaInstallBanner')
      const installBtn = document.getElementById('pwaInstallBtn') as HTMLButtonElement | null
      const closeBtn = document.getElementById('pwaInstallClose')
      const iosModal = document.getElementById('iosInstallModal')
      const iosClose = document.getElementById('iosInstallClose')

      const ua = navigator.userAgent
      const isIOS = /iPad|iPhone|iPod/.test(ua) && !(window as any).MSStream
      const isStandalone =
        window.matchMedia('(display-mode: standalone)').matches ||
        (navigator as any).standalone === true
      const dismissedAt = parseInt(localStorage.getItem('pwa-dismiss') || '0', 10)
      const dismissedRecently = Date.now() - dismissedAt < 14 * 24 * 60 * 60 * 1000

      let deferredPrompt: any = null
      let bannerShown = false

      function showBanner() {
        if (!banner || isStandalone || dismissedRecently || bannerShown) return
        bannerShown = true
        banner.classList.remove('hidden')
        // body'yi banner kadar aşağı it
        document.body.style.paddingTop = banner.offsetHeight + 'px'
        // bir frame sonra slide-down animasyonu başlat
        requestAnimationFrame(() => {
          banner.classList.remove('-translate-y-full')
        })
      }
      function hideBanner(persist = false) {
        if (!banner) return
        banner.classList.add('-translate-y-full')
        document.body.style.paddingTop = ''
        setTimeout(() => banner.classList.add('hidden'), 500)
        if (persist) localStorage.setItem('pwa-dismiss', String(Date.now()))
      }

      // Android — native install hazır
      window.addEventListener('beforeinstallprompt', (e: any) => {
        e.preventDefault()
        deferredPrompt = e
        // 1.5sn gecikmeyle göster — sayfa yüklenmesini bozmasın
        setTimeout(showBanner, 1500)
      })

      // iOS Safari — beforeinstallprompt yok, kendi banner'ımızla göster
      if (isIOS && !isStandalone && !dismissedRecently) {
        setTimeout(showBanner, 1500)
      }

      // Android — beforeinstallprompt 4sn'de gelmediyse fallback olarak göster
      // (kullanıcı manuel olarak menüden yüklemek isteyebilir)
      setTimeout(() => {
        if (!isStandalone && !dismissedRecently && !bannerShown) showBanner()
      }, 4000)

      installBtn?.addEventListener('click', async () => {
        if (deferredPrompt) {
          deferredPrompt.prompt()
          const choice = await deferredPrompt.userChoice
          if (choice.outcome === 'accepted') hideBanner(true)
          deferredPrompt = null
        } else if (isIOS) {
          iosModal?.classList.remove('hidden')
          iosModal?.classList.add('flex')
        } else {
          // Android beforeinstallprompt henüz tetiklenmediyse: tarayıcı menüsünü göster
          alert('Tarayıcı menüsünden (⋮) "Uygulamayı yükle" / "Ana Ekrana Ekle" seçeneğine dokunun.')
        }
      })
      closeBtn?.addEventListener('click', () => hideBanner(true))
      iosClose?.addEventListener('click', () => {
        iosModal?.classList.add('hidden')
        iosModal?.classList.remove('flex')
      })
      iosModal?.addEventListener('click', (e) => {
        if (e.target === iosModal) {
          iosModal.classList.add('hidden')
          iosModal.classList.remove('flex')
        }
      })

      // Scroll reveal — IntersectionObserver
      if (typeof window !== 'undefined' && 'IntersectionObserver' in window) {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
        if (!reduce) {
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add('is-visible')
                  io.unobserve(entry.target)
                }
              })
            },
            { rootMargin: '0px 0px -10% 0px', threshold: 0.05 },
          )
          const observe = () =>
            document.querySelectorAll('[data-reveal]:not(.is-visible)').forEach((el) => io.observe(el))
          observe()
          // Astro client navigation sonrası tekrar bağla
          document.addEventListener('astro:after-swap', observe)
        } else {
          document.querySelectorAll('[data-reveal]').forEach((el) => el.classList.add('is-visible'))
        }
      }
    </script>
  </body>
</html>
