---
import '../styles/globals.css'

interface Props {
  title?: string
  current?: 'dashboard' | 'orders' | 'new' | 'quotes' | 'stock'
}
const { title = 'Yönetim', current = 'dashboard' } = Astro.props

const NAV = [
  { key: 'dashboard', href: '/admin', label: 'Gösterge', icon: 'M3 12l9-9 9 9M5 10v10h4v-6h6v6h4V10' },
  { key: 'quotes', href: '/admin/talepler', label: 'Talepler', icon: 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z', badge: 'quotes' as const },
  { key: 'orders', href: '/admin/orders', label: 'Siparişler', icon: 'M9 11l3 3 8-8M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0z' },
  { key: 'stock', href: '/admin/stok', label: 'Stok', icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z M3.27 6.96 12 12.01l8.73-5.05 M12 22.08V12', badge: 'stock' as const },
  { key: 'new', href: '/admin/orders/new', label: 'Yeni Sipariş', icon: 'M12 5v14M5 12h14' },
]

// Talepler badge — bekleyen ön talep sayısı
import { listOrders } from '../server/db'
import { getCriticalItems } from '../server/stock'
const allOrders = listOrders()
const pendingQuotes = allOrders.filter((o) => o.kind === 'quote' && o.productionStatus === 'received').length
const criticalStockCount = (() => { try { return getCriticalItems().length } catch { return 0 } })()
---

<!doctype html>
<html lang="tr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0B0B0F" />
    <meta name="robots" content="noindex,nofollow" />
    <title>{title} · PaspasOto Yönetim</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/admin-manifest.webmanifest" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen">
    {/* PWA Install Smart Banner — admin tarafı için tepeden kayan otomatik davet */}
    <div
      id="pwaInstallBanner"
      class="hidden fixed top-0 left-0 right-0 z-[60] px-3 py-2.5 bg-gradient-to-r from-[var(--color-primary)] via-amber-400 to-[var(--color-primary)] text-[var(--color-bg)] shadow-xl shadow-amber-500/30 transform -translate-y-full transition-transform duration-500"
    >
      <div class="max-w-2xl mx-auto flex items-center gap-3">
        <span class="size-10 grid place-items-center rounded-xl bg-black/20 ring-1 ring-black/10 shrink-0">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14" />
          </svg>
        </span>
        <div class="flex-1 min-w-0">
          <div class="font-bold text-sm leading-tight">Yönetim panelini ana ekrana ekle</div>
          <div class="text-[11px] opacity-85 leading-tight mt-0.5 truncate">Sipariş bildirimlerini telefonundan al · Tek dokunuşla aç</div>
        </div>
        <button id="pwaInstallBtn" type="button" class="px-3.5 py-2 rounded-xl bg-black hover:bg-black/85 text-white text-xs font-bold whitespace-nowrap shadow-md">
          Ekle
        </button>
        <button id="pwaInstallClose" type="button" aria-label="Kapat" class="size-8 grid place-items-center rounded-xl hover:bg-black/15 shrink-0">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12" /></svg>
        </button>
      </div>
    </div>

    {/* iOS install instructions modal — admin */}
    <div id="iosInstallModal" class="hidden fixed inset-0 z-[70] grid place-items-end md:place-items-center bg-black/70 backdrop-blur-sm p-4">
      <div class="w-full md:max-w-sm rounded-t-2xl md:rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 p-5">
        <div class="flex items-start justify-between gap-3 mb-3">
          <div>
            <h3 class="font-display font-semibold">iPhone'a Yükle</h3>
            <p class="text-xs text-[var(--color-text-muted)] mt-0.5">Yönetim panelini uygulamadan kullan</p>
          </div>
          <button id="iosInstallClose" type="button" aria-label="Kapat" class="size-7 grid place-items-center rounded-lg hover:bg-[var(--color-surface-2)]">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12" /></svg>
          </button>
        </div>
        <ol class="space-y-3 text-sm">
          <li class="flex items-start gap-3">
            <span class="size-7 grid place-items-center rounded-full bg-[var(--color-primary)] text-[var(--color-bg)] font-bold text-xs shrink-0">1</span>
            <div>Safari'de alttaki <span class="font-semibold text-[var(--color-primary)]">Paylaş</span> butonuna basın</div>
          </li>
          <li class="flex items-start gap-3">
            <span class="size-7 grid place-items-center rounded-full bg-[var(--color-primary)] text-[var(--color-bg)] font-bold text-xs shrink-0">2</span>
            <div><span class="font-semibold text-[var(--color-primary)]">"Ana Ekrana Ekle"</span> seçin</div>
          </li>
          <li class="flex items-start gap-3">
            <span class="size-7 grid place-items-center rounded-full bg-[var(--color-primary)] text-[var(--color-bg)] font-bold text-xs shrink-0">3</span>
            <div>Sağ üst <span class="font-semibold text-[var(--color-primary)]">"Ekle"</span> butonuna basın</div>
          </li>
        </ol>
      </div>
    </div>

    {/* MOBILE TOP BAR — sadece logo + sayfa başlığı (hamburger yok, bottom nav var) */}
    <header class="md:hidden sticky top-0 z-30 flex items-center justify-center gap-3 px-4 h-12 bg-[var(--color-surface)]/85 border-b border-[var(--color-border)]/40 backdrop-blur-md">
      <a href="/admin" class="flex items-center gap-2">
        <img src="/images/paspasoto_logo_1778184847608.png" alt="PaspasOto" class="h-8 w-auto object-contain" />
        <span class="text-[10px] uppercase tracking-[0.18em] text-[var(--color-text-muted)] font-semibold">Yönetim</span>
      </a>
    </header>

    <div class="flex min-h-screen md:flex-row flex-col pb-[calc(64px+env(safe-area-inset-bottom))] md:pb-0">
      {/* SIDEBAR — sadece md+ */}
      <aside
        id="adminSidebar"
        class="hidden md:flex md:static md:w-64 shrink-0 md:translate-x-0 border-r border-[var(--color-border)]/60 bg-[var(--color-surface)] flex-col"
      >
        {/* Logo + close button */}
        <div class="flex items-center justify-between p-5 border-b border-[var(--color-border)]/60">
          <a href="/admin" class="flex items-center gap-3">
            <img src="/images/paspasoto_logo_1778184847608.png" alt="PaspasOto" class="h-10 w-auto object-contain drop-shadow-[0_0_10px_rgba(255,255,255,0.05)]" />
            <div class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)] font-semibold">Yönetim</div>
          </a>
          <button id="adminNavClose" type="button" aria-label="Menüyü kapat" class="md:hidden size-8 grid place-items-center rounded-lg hover:bg-[var(--color-surface-2)]">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12" /></svg>
          </button>
        </div>

        {/* Müşteri sitesi geçiş — üstte belirgin */}
        <a
          href="/"
          class="mx-3 mt-3 mb-1 flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-semibold bg-gradient-to-br from-[var(--color-primary-soft)] to-[var(--color-surface-2)] border border-[var(--color-primary)]/30 text-[var(--color-primary)] hover:border-[var(--color-primary)]/60 transition-colors"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M3 12l9-9 9 9M5 10v10h14V10" />
          </svg>
          Müşteri Anasayfası ↗
        </a>

        <nav class="flex-1 p-3">
          <div class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)] font-semibold px-3 mb-2 mt-2">Yönetim</div>
          <ul class="space-y-1">
            {
              NAV.map((n) => (
                <li>
                  <a
                    href={n.href}
                    class={[
                      'flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium transition-colors',
                      current === n.key
                        ? 'bg-[var(--color-primary-soft)] text-[var(--color-primary)]'
                        : 'text-[var(--color-text-soft)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-2)]',
                    ].join(' ')}
                  >
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d={n.icon} />
                    </svg>
                    <span class="flex-1">{n.label}</span>
                    {n.badge === 'quotes' && pendingQuotes > 0 && (
                      <span class="px-1.5 py-0.5 rounded-full text-[10px] font-bold bg-amber-500 text-black">{pendingQuotes}</span>
                    )}
                    {n.badge === 'stock' && criticalStockCount > 0 && (
                      <span class="px-1.5 py-0.5 rounded-full text-[10px] font-bold bg-red-500 text-white">{criticalStockCount}</span>
                    )}
                  </a>
                </li>
              ))
            }
          </ul>

          <div class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)] font-semibold px-3 mb-2 mt-6">Hızlı Erişim</div>
          <ul class="space-y-1">
            <li>
              <a href="/konfigurator" target="_blank" class="flex items-center gap-3 px-3 py-2 rounded-lg text-xs text-[var(--color-text-soft)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-2)]">
                <span>🎨</span> Konfigüratör
              </a>
            </li>
            <li>
              <a href="/siparis-takip" target="_blank" class="flex items-center gap-3 px-3 py-2 rounded-lg text-xs text-[var(--color-text-soft)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface-2)]">
                <span>📦</span> Müşteri Takip
              </a>
            </li>
          </ul>
        </nav>

        <div class="p-3 border-t border-[var(--color-border)]/60">
          <form method="POST" action="/api/auth/logout">
            <button
              type="submit"
              class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-sm font-medium text-[var(--color-text-muted)] hover:text-[var(--color-danger)] hover:bg-[var(--color-surface-2)] transition-colors"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" />
              </svg>
              Çıkış
            </button>
          </form>
        </div>
      </aside>

      <main class="flex-1 min-w-0">
        <slot />
      </main>
    </div>

    {/* MOBILE BOTTOM NAV — native uygulama tarzı tab bar */}
    <nav
      class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-[var(--color-surface)]/95 backdrop-blur-lg border-t border-[var(--color-border)]/60"
      style="padding-bottom: env(safe-area-inset-bottom);"
      aria-label="Yönetim navigasyon"
    >
      <div class="grid grid-cols-5 gap-1 px-2 pt-2 pb-1">
        {([
          { key: 'quotes', href: '/admin/talepler', label: 'Talepler', icon: 'M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z', badge: pendingQuotes, badgeColor: 'amber' as const },
          { key: 'orders', href: '/admin/orders', label: 'Siparişler', icon: 'M9 11l3 3 8-8M3 12a9 9 0 1 0 18 0 9 9 0 0 0-18 0z' },
          { key: 'new', href: '/admin/orders/new', label: 'Yeni', icon: 'M12 5v14M5 12h14', isFab: true },
          { key: 'stock', href: '/admin/stok', label: 'Stok', icon: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z', badge: criticalStockCount, badgeColor: 'red' as const },
          { key: 'menu', href: '#', label: 'Menü', icon: 'M3 6h18M3 12h18M3 18h18', isMenu: true },
        ] as const).map((it) => {
          const active = current === it.key
          if (it.isFab) {
            return (
              <a
                href={it.href}
                class="flex flex-col items-center justify-center gap-0.5 -mt-3"
                aria-current={active ? 'page' : undefined}
              >
                <span class="size-12 grid place-items-center rounded-full bg-[var(--color-primary)] text-[var(--color-bg)] shadow-xl shadow-[var(--color-primary)]/30 ring-2 ring-[var(--color-bg)]">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d={it.icon} /></svg>
                </span>
                <span class="text-[10px] font-bold text-[var(--color-primary)]">{it.label}</span>
              </a>
            )
          }
          return (
            <a
              href={it.href}
              data-action={it.isMenu ? 'open-menu' : undefined}
              class={[
                'relative flex flex-col items-center justify-center gap-0.5 py-1.5 rounded-xl transition-colors',
                active
                  ? 'text-[var(--color-primary)]'
                  : 'text-[var(--color-text-muted)] active:bg-[var(--color-surface-2)]',
              ].join(' ')}
              aria-current={active ? 'page' : undefined}
            >
              <span class={['size-9 grid place-items-center rounded-xl', active ? 'bg-[var(--color-primary-soft)]' : ''].join(' ')}>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={it.icon} /></svg>
                {'badge' in it && it.badge && it.badge > 0 && (
                  <span class={[
                    'absolute top-0.5 right-2 size-4 grid place-items-center rounded-full text-[9px] font-bold ring-2 ring-[var(--color-surface)]',
                    it.badgeColor === 'red' ? 'bg-red-500 text-white' : 'bg-amber-500 text-black',
                  ].join(' ')}>{it.badge}</span>
                )}
              </span>
              <span class="text-[10px] font-semibold tracking-tight">{it.label}</span>
            </a>
          )
        })}
      </div>
    </nav>

    {/* MOBILE MENU SHEET — bottom nav 'Menü' butonuna basınca açılır */}
    <div id="adminMenuSheet" class="md:hidden hidden fixed inset-0 z-[55]">
      <div data-close="menu" class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
      <div class="absolute bottom-0 left-0 right-0 bg-[var(--color-surface)] rounded-t-3xl border-t border-[var(--color-border)] p-5 pb-[calc(20px+env(safe-area-inset-bottom))] space-y-2">
        <div class="size-12 h-1.5 bg-[var(--color-border)] rounded-full mx-auto mb-3"></div>
        <a href="/admin" class="flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-semibold bg-[var(--color-surface-2)] hover:bg-[var(--color-border)]/40">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l9-9 9 9M5 10v10h4v-6h6v6h4V10" /></svg>
          Gösterge Paneli (Analiz)
        </a>
        <a href="/" class="flex items-center gap-3 px-3 py-3 rounded-xl bg-gradient-to-br from-[var(--color-primary-soft)] to-[var(--color-surface-2)] border border-[var(--color-primary)]/30 text-[var(--color-primary)] font-semibold">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12l9-9 9 9M5 10v10h14V10" /></svg>
          Müşteri Anasayfası ↗
        </a>
        <a href="/konfigurator" target="_blank" class="flex items-center gap-3 px-3 py-3 rounded-xl text-sm bg-[var(--color-surface-2)] hover:bg-[var(--color-border)]/40">
          <span>🎨</span> Konfigüratör (yeni sekmede)
        </a>
        <a href="/siparis-takip" target="_blank" class="flex items-center gap-3 px-3 py-3 rounded-xl text-sm bg-[var(--color-surface-2)] hover:bg-[var(--color-border)]/40">
          <span>📦</span> Müşteri Sipariş Takip (yeni sekmede)
        </a>
        <form method="POST" action="/api/auth/logout">
          <button type="submit" class="w-full flex items-center gap-3 px-3 py-3 rounded-xl text-sm font-medium border border-[var(--color-danger)]/30 text-[var(--color-danger)] hover:bg-[var(--color-danger)]/10">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4M16 17l5-5-5-5M21 12H9" /></svg>
            Çıkış Yap
          </button>
        </form>
        <button type="button" data-close="menu" class="w-full px-3 py-2.5 rounded-xl text-xs text-[var(--color-text-muted)]">
          Kapat
        </button>
      </div>
    </div>

    <script>
      // Mobile bottom nav 'Menü' sheet
      const menuSheet = document.getElementById('adminMenuSheet')
      document.querySelectorAll('[data-action="open-menu"]').forEach((el) => {
        el.addEventListener('click', (e) => {
          e.preventDefault()
          menuSheet?.classList.remove('hidden')
        })
      })
      menuSheet?.querySelectorAll('[data-close="menu"]').forEach((el) => {
        el.addEventListener('click', () => menuSheet.classList.add('hidden'))
      })

      // Service worker
      if ('serviceWorker' in navigator && location.protocol === 'https:') {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js', { scope: '/' }).catch(() => {})
        })
      }

      // PWA install — tepeden kayan smart banner
      const banner = document.getElementById('pwaInstallBanner')
      const installBtn = document.getElementById('pwaInstallBtn') as HTMLButtonElement | null
      const closeBtn = document.getElementById('pwaInstallClose')
      const iosModal = document.getElementById('iosInstallModal')
      const iosClose = document.getElementById('iosInstallClose')

      const ua = navigator.userAgent
      const isIOS = /iPad|iPhone|iPod/.test(ua) && !(window as any).MSStream
      const isStandalone =
        window.matchMedia('(display-mode: standalone)').matches ||
        (navigator as any).standalone === true
      const dismissedAt = parseInt(localStorage.getItem('pwa-admin-dismiss') || '0', 10)
      const dismissedRecently = Date.now() - dismissedAt < 14 * 24 * 60 * 60 * 1000

      let deferred: any = null
      let bannerShown = false

      function showBanner() {
        if (!banner || isStandalone || dismissedRecently || bannerShown) return
        bannerShown = true
        banner.classList.remove('hidden')
        document.body.style.paddingTop = banner.offsetHeight + 'px'
        requestAnimationFrame(() => banner.classList.remove('-translate-y-full'))
      }
      function hideBanner(persist = false) {
        if (!banner) return
        banner.classList.add('-translate-y-full')
        document.body.style.paddingTop = ''
        setTimeout(() => banner.classList.add('hidden'), 500)
        if (persist) localStorage.setItem('pwa-admin-dismiss', String(Date.now()))
      }

      window.addEventListener('beforeinstallprompt', (e: any) => {
        e.preventDefault()
        deferred = e
        setTimeout(showBanner, 1500)
      })
      if (isIOS && !isStandalone && !dismissedRecently) {
        setTimeout(showBanner, 1500)
      }
      setTimeout(() => {
        if (!isStandalone && !dismissedRecently && !bannerShown) showBanner()
      }, 4000)

      installBtn?.addEventListener('click', async () => {
        if (deferred) {
          deferred.prompt()
          const choice = await deferred.userChoice
          if (choice.outcome === 'accepted') hideBanner(true)
          deferred = null
        } else if (isIOS) {
          iosModal?.classList.remove('hidden')
          iosModal?.classList.add('flex')
        } else {
          alert('Tarayıcı menüsünden (⋮) "Uygulamayı yükle" / "Ana Ekrana Ekle" seçin.')
        }
      })
      closeBtn?.addEventListener('click', () => hideBanner(true))
      iosClose?.addEventListener('click', () => {
        iosModal?.classList.add('hidden')
        iosModal?.classList.remove('flex')
      })
      iosModal?.addEventListener('click', (e) => {
        if (e.target === iosModal) {
          iosModal.classList.add('hidden')
          iosModal.classList.remove('flex')
        }
      })

      // === Web Push abonesi (admin) ===
      // Notification permission verildiyse SW üzerinden push subscribe edilir
      // Bu sayede tarayıcı kapalıyken bile yeni talep/sipariş bildirimi alınır
      async function ensureAdminPushSubscription() {
        if (!('serviceWorker' in navigator) || !('PushManager' in window)) return
        if (Notification.permission !== 'granted') return
        try {
          const reg = await navigator.serviceWorker.ready
          let sub = await reg.pushManager.getSubscription()
          if (!sub) {
            const r = await fetch('/api/push/vapid')
            const { publicKey } = await r.json()
            if (!publicKey) return
            const appKey = urlBase64ToUint8Array(publicKey)
            sub = await reg.pushManager.subscribe({ userVisibleOnly: true, applicationServerKey: appKey })
          }
          await fetch('/api/push/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ subscription: sub.toJSON(), audience: 'admin' }),
          })
        } catch (e) {
          console.warn('[push] admin subscribe hatası:', e)
        }
      }
      function urlBase64ToUint8Array(base64String: string): Uint8Array {
        const padding = '='.repeat((4 - (base64String.length % 4)) % 4)
        const base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/')
        const raw = atob(base64)
        const out = new Uint8Array(raw.length)
        for (let i = 0; i < raw.length; i++) out[i] = raw.charCodeAt(i)
        return out
      }

      // === Bildirim sistemi (admin tarafı) — push + polling fallback ===
      // 30 saniyede bir polling: yeni talep/sipariş kontrol et,
      // yenisi varsa Notification API + ses + sayfa tepesinde toast
      type Snapshot = { quotes: number; lastQuoteOrder?: string; lastQuoteCustomer?: string }
      const STORAGE_KEY = 'admin-last-snapshot'
      const audioCtx: AudioContext | null = null

      function playBeep() {
        try {
          // basit "ding" tonu — webaudio
          const ctx = new (window.AudioContext || (window as any).webkitAudioContext)()
          const osc = ctx.createOscillator()
          const gain = ctx.createGain()
          osc.frequency.value = 880
          gain.gain.value = 0.15
          osc.connect(gain).connect(ctx.destination)
          osc.start()
          gain.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + 0.6)
          osc.stop(ctx.currentTime + 0.6)
        } catch {}
      }

      async function notify(title: string, body: string, url: string) {
        playBeep()
        if ('Notification' in window) {
          if (Notification.permission === 'default') {
            await Notification.requestPermission()
          }
          if (Notification.permission === 'granted') {
            const n = new Notification(title, { body, icon: '/icons/icon-192.png', tag: 'carmat-admin' })
            n.onclick = () => { window.focus(); window.location.href = url }
          }
        }
        // Sayfa içi toast
        const t = document.createElement('a')
        t.href = url
        t.className = 'fixed top-4 right-4 z-[60] px-4 py-3 rounded-xl bg-amber-500 text-black font-semibold text-sm shadow-2xl ring-2 ring-amber-300 cursor-pointer animate-pulse max-w-xs'
        t.innerHTML = `<div class="flex items-center gap-2"><span>🔔</span><div><div>${title}</div><div class="text-[10px] font-medium opacity-80">${body}</div></div></div>`
        document.body.appendChild(t)
        setTimeout(() => t.remove(), 8000)
      }

      async function pollQuotes() {
        try {
          const res = await fetch('/api/orders/quotes-summary', { credentials: 'same-origin' })
          if (!res.ok) return
          const snapshot: Snapshot = await res.json()
          const prevRaw = localStorage.getItem(STORAGE_KEY)
          const prev: Snapshot | null = prevRaw ? JSON.parse(prevRaw) : null
          if (prev && snapshot.lastQuoteOrder && prev.lastQuoteOrder !== snapshot.lastQuoteOrder) {
            // Yeni talep geldi
            notify(
              'Yeni Teklif Talebi 🎉',
              `${snapshot.lastQuoteCustomer ?? ''} — ${snapshot.lastQuoteOrder}`,
              '/admin/talepler',
            )
          }
          localStorage.setItem(STORAGE_KEY, JSON.stringify(snapshot))
        } catch {}
      }

      // İlk açılışta permission iste + verilirse push subscribe et
      async function setupNotifications() {
        if (!('Notification' in window)) return
        if (Notification.permission === 'default') {
          await Notification.requestPermission().catch(() => {})
        }
        if (Notification.permission === 'granted') {
          await ensureAdminPushSubscription()
        }
      }
      setTimeout(setupNotifications, 3000)

      // Polling fallback (tab açıkken anında bildirim için)
      pollQuotes()
      setInterval(pollQuotes, 30000)
    </script>
  </body>
</html>
