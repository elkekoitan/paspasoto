---
export const prerender = false
import AdminLayout from '@layouts/AdminLayout.astro'
import { getSession } from '../../server/auth'
import { listOrders } from '../../server/db'
import { formatTRY, formatDateTime } from '@lib/format'

if (!getSession(Astro.cookies)) return Astro.redirect('/admin/login')

const all = listOrders()
// Sadece müşteri-tarafından gelen ön talepler
const quotes = all.filter((o) => o.kind === 'quote')
const newQuotes = quotes.filter((o) => o.productionStatus === 'received')
---

<AdminLayout title="Talepler" current="quotes">
  <div class="p-6 md:p-10 max-w-7xl mx-auto">
    <header class="flex items-end justify-between gap-4 mb-6 flex-wrap">
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-primary)] font-semibold">Müşteri Talepleri</p>
        <h1 class="mt-2 font-display text-3xl font-semibold">Ön Teklif Talepleri</h1>
        <p class="mt-1.5 text-sm text-[var(--color-text-soft)]">
          Konfigüratör üzerinden gelen ön talepler. WhatsApp'tan müşteriye fiyat teklifi gönderin, onay aldığınızda siparişe çevirin.
        </p>
      </div>
      <div class="flex items-center gap-3">
        <span class="px-3 py-1.5 rounded-full bg-amber-500/15 border border-amber-500/30 text-amber-400 text-xs font-semibold">
          {newQuotes.length} bekleyen
        </span>
      </div>
    </header>

    {quotes.length === 0 ? (
      <div class="p-12 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 text-center">
        <div class="size-12 rounded-full bg-[var(--color-surface-2)] grid place-items-center mx-auto mb-3">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--color-text-muted)]"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
        </div>
        <p class="text-sm text-[var(--color-text-muted)]">Henüz ön talep yok.</p>
        <p class="mt-1 text-xs text-[var(--color-text-muted)]">
          Müşteriler konfigüratörden teklif istediğinde burada görünür.
        </p>
      </div>
    ) : (
      <div class="space-y-3">
        {quotes.map((q) => {
          const i = q.items[0]
          const phoneIntl = q.customer.phone.replace(/\D/g, '').replace(/^0/, '90')
          const message = encodeURIComponent(
            [
              `Merhaba ${q.customer.fullName}, Carmat'tan ulaşıyorum.`,
              ``,
              `Talebiniz için teklifimiz:`,
              ``,
              `🚗 Araç: ${i?.brandName} ${i?.modelName} ${i?.modelChassis}`,
              `📦 Set: ${i?.productName}`,
              `🎨 Zemin: ${i?.matName} · Kenarlık: ${i?.borderName}`,
              `👟 Topukluk: ${i?.heelName}${i?.heelPadPassenger ? ' (yolcu+sürücü)' : ''}`,
              i?.logoBrandSlug ? `🏷 Amblem: ${i.brandName} × ${i.logoQty}` : '',
              ``,
              `💰 Toplam: ${formatTRY(q.total)}`,
              ``,
              `Onaylarsanız üretime alıp en kısa sürede teslim ederiz. Soru / değişiklik için yazabilirsiniz.`,
              ``,
              `Talep no: ${q.orderNo}`,
            ]
              .filter(Boolean)
              .join('\n'),
          )
          const isOld = Date.now() - q.createdAt > 24 * 60 * 60 * 1000
          const isNew = q.productionStatus === 'received'
          return (
            <div class="p-4 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 hover:border-[var(--color-primary)]/30 transition-colors">
              <div class="flex flex-col md:flex-row md:items-start gap-4">
                {/* Sol: Müşteri + Araç */}
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                    <span class="font-mono text-[10px] text-[var(--color-text-muted)]">{q.orderNo}</span>
                    {isNew && (
                      <span class="px-1.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider bg-amber-500 text-black">
                        Yeni Talep
                      </span>
                    )}
                    {isOld && isNew && (
                      <span class="px-1.5 py-0.5 rounded-full text-[9px] font-semibold bg-red-500/15 text-red-400 border border-red-500/30">
                        24h+ bekliyor
                      </span>
                    )}
                    <span class="text-[10px] text-[var(--color-text-muted)]">{formatDateTime(q.createdAt)}</span>
                  </div>
                  <div class="font-display font-semibold text-base">{q.customer.fullName}</div>
                  <div class="text-xs text-[var(--color-text-muted)] flex items-center gap-3 mt-0.5">
                    <a href={`tel:${q.customer.phone}`} class="hover:text-[var(--color-primary)]">📞 {q.customer.phone}</a>
                  </div>
                  {i && (
                    <div class="mt-3 flex items-center gap-3">
                      <div class="size-12 rounded-lg overflow-hidden ring-1 ring-[var(--color-border)] relative shrink-0">
                        <img src={i.borderSwatchUrl} alt="" class="absolute inset-0 size-full object-cover" />
                        <div class="absolute inset-[14%] rounded-sm overflow-hidden">
                          <img src={i.matSwatchUrl} alt="" class="size-full object-cover" />
                        </div>
                      </div>
                      <div class="min-w-0 flex-1">
                        <div class="text-sm font-medium">{i.brandName} {i.modelName} {i.modelChassis}</div>
                        <div class="text-[10px] text-[var(--color-text-muted)] truncate">
                          {i.productName} · {i.matName} · {i.borderName} · {i.heelName}
                          {i.heelPadPassenger ? ' · yolcu topukluk' : ''}
                          {i.logoBrandSlug ? ` · ${i.brandName} amblem` : ''}
                        </div>
                      </div>
                    </div>
                  )}
                </div>

                {/* Sağ: Tutar + Aksiyonlar */}
                <div class="md:text-right md:min-w-[260px]">
                  <div class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] font-semibold">Tahmini Tutar</div>
                  <div class="font-display text-2xl font-semibold tabular-nums text-[var(--color-primary)]">{formatTRY(q.total)}</div>

                  <div class="mt-3 flex flex-wrap md:justify-end gap-2">
                    <a
                      href={`https://wa.me/${phoneIntl}?text=${message}`}
                      target="_blank"
                      rel="noopener"
                      class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-semibold bg-emerald-500 hover:bg-emerald-400 text-white transition-colors"
                    >
                      <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.16 5.335 5.495 0 12.05 0c3.181 0 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.414 0 6.557-5.336 11.892-11.893 11.892-1.99 0-3.951-.5-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884-.001 2.225.651 3.891 1.746 5.634l-.999 3.648 3.742-.981z"/></svg>
                      Teklif Gönder
                    </a>
                    <a
                      href={`/admin/orders/${q.orderNo}`}
                      class="inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-semibold border border-[var(--color-border)] hover:bg-[var(--color-surface-2)]"
                    >
                      Detay →
                    </a>
                    <button
                      type="button"
                      data-convert={q.orderNo}
                      class="convert-btn inline-flex items-center gap-1.5 px-3 py-2 rounded-lg text-xs font-semibold bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-[var(--color-bg)]"
                    >
                      ✓ Siparişe Çevir
                    </button>
                  </div>
                </div>
              </div>
            </div>
          )
        })}
      </div>
    )}
  </div>

  <script>
    // "Siparişe Çevir" — kind=order yapar + status=in_production
    document.querySelectorAll<HTMLButtonElement>('.convert-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const orderNo = btn.dataset.convert
        if (!orderNo) return
        if (!confirm(`${orderNo} siparişe dönüştürülecek. Müşteri onay verdi mi?`)) return
        btn.disabled = true
        btn.textContent = 'Dönüştürülüyor...'
        try {
          const res = await fetch(`/api/orders/${orderNo}`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({
              kind: 'order',
              productionStatus: 'in_production',
            }),
          })
          if (res.ok) {
            window.location.href = `/admin/orders/${orderNo}`
          } else {
            alert('Hata: ' + (await res.text()))
            btn.disabled = false
            btn.textContent = '✓ Siparişe Çevir'
          }
        } catch (e: any) {
          alert('Bağlantı hatası')
          btn.disabled = false
          btn.textContent = '✓ Siparişe Çevir'
        }
      })
    })
  </script>
</AdminLayout>
