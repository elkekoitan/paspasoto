---
export const prerender = false
import AdminLayout from '@layouts/AdminLayout.astro'
import { getSession } from '../../server/auth'
import { listContent } from '../../server/content'
import { getMergedProducts } from '../../server/catalog-merged'
import ContentManager from '@components/admin/ContentManager.tsx'

if (!getSession(Astro.cookies)) return Astro.redirect('/admin/login')

const overrides = listContent()
const products = getMergedProducts()
---

<AdminLayout title="İçerik & Ürün Tasarım" current="icerik">
  <div class="p-4 md:p-8 max-w-7xl mx-auto">
    <header class="mb-6">
      <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-primary)] font-semibold">Admin</p>
      <h1 class="mt-1 font-display text-2xl md:text-3xl font-bold">İçerik &amp; Ürün Tasarım</h1>
      <p class="mt-2 text-sm text-[var(--color-text-soft)] max-w-2xl">
        Basit ürünlerin görsellerini ve açıklamalarını burada güncelleyin.
        Aynı sayfada konfigüratördeki paspas rengi, kenarlık, topukluk ve logo
        swatchları için de gerçek dokulu görsel URL'leri ekleyebilirsiniz.
        Değişiklikler kaydedildiği an canlıya yansır.
      </p>
    </header>
    <ContentManager initialOverrides={overrides} products={products} client:load />
  </div>
</AdminLayout>
