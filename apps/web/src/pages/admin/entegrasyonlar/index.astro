---
export const prerender = false
import AdminLayout from '@layouts/AdminLayout.astro'
import { getCurrentUser } from '../../../server/auth'
import { listEvents } from '../../../server/integrations/events-log'
import { listMappings } from '../../../server/integrations/trendyol-mapping'
import { formatDateTime } from '@lib/format'

const _me = getCurrentUser(Astro.cookies)
if (!_me) return Astro.redirect('/admin/login')
if (_me.role !== 'patron') return new Response('Forbidden', { status: 403 })

const events = listEvents(50)
const trendyolMappings = listMappings('trendyol')

const STATUS_COLOR: Record<string, string> = {
  success: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30',
  duplicate: 'bg-blue-500/15 text-blue-400 border-blue-500/30',
  unmapped: 'bg-amber-500/15 text-amber-400 border-amber-500/30',
  invalid_signature: 'bg-red-500/15 text-red-400 border-red-500/30',
  parse_error: 'bg-red-500/15 text-red-400 border-red-500/30',
  error: 'bg-red-500/15 text-red-400 border-red-500/30',
}

const STATUS_LABEL: Record<string, string> = {
  success: 'Başarılı',
  duplicate: 'Mükerrer',
  unmapped: 'Eşleşmemiş ürün',
  invalid_signature: 'İmza geçersiz',
  parse_error: 'Parse hatası',
  error: 'Hata',
}

const PLATFORMS = [
  {
    key: 'trendyol' as const,
    label: 'Trendyol',
    logo: '🛒',
    secretEnv: 'TRENDYOL_WEBHOOK_SECRET',
    webhookPath: '/api/integrations/trendyol/webhook',
    docsLink: 'https://partner.trendyol.com',
    mappings: trendyolMappings.length,
    enabled: !!process.env.TRENDYOL_WEBHOOK_SECRET,
  },
  // Hepsiburada / WooCommerce / Shopify ileri sürümlerde
]

const baseUrl = process.env.PUBLIC_SITE_URL || import.meta.env.PUBLIC_SITE_URL || Astro.url.origin
---

<AdminLayout title="Entegrasyonlar" current="dashboard">
  <div class="p-4 md:p-10 max-w-6xl mx-auto">
    <header class="mb-6">
      <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-primary)] font-semibold">E-Ticaret</p>
      <h1 class="mt-2 font-display text-3xl font-semibold">Pazaryeri Entegrasyonları</h1>
      <p class="mt-1.5 text-sm text-[var(--color-text-soft)]">
        Trendyol, Hepsiburada gibi platformlardan gelen siparişler webhook ile otomatik üretime düşer.
      </p>
    </header>

    {/* Platform kartları */}
    <div class="grid md:grid-cols-2 gap-4 mb-8">
      {PLATFORMS.map((p) => (
        <section class="rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 p-5">
          <div class="flex items-start justify-between gap-3 mb-3">
            <div class="flex items-center gap-3">
              <div class="size-10 rounded-xl grid place-items-center text-xl bg-[var(--color-surface-2)]">{p.logo}</div>
              <div>
                <div class="font-display font-semibold">{p.label}</div>
                <div class="text-[10px] text-[var(--color-text-muted)]">{p.mappings} ürün eşleşmesi</div>
              </div>
            </div>
            <span class={[
              'px-2 py-0.5 rounded-full text-[10px] font-bold',
              p.enabled ? 'bg-emerald-500/15 text-emerald-400 border border-emerald-500/30' : 'bg-[var(--color-surface-2)] text-[var(--color-text-muted)] border border-[var(--color-border)]/40',
            ].join(' ')}>{p.enabled ? 'AKTİF' : 'PASİF'}</span>
          </div>

          <dl class="space-y-2 text-xs">
            <div>
              <dt class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] font-semibold mb-1">Webhook URL</dt>
              <dd class="flex items-center gap-2">
                <code class="flex-1 px-2 py-1.5 rounded bg-[var(--color-surface-2)] font-mono text-[10px] text-[var(--color-primary)] truncate">{baseUrl}{p.webhookPath}</code>
                <button class="copy-url-btn px-2 py-1 text-[10px] rounded bg-[var(--color-surface-2)] hover:bg-[var(--color-border)]/40" data-url={`${baseUrl}${p.webhookPath}`}>Kopyala</button>
              </dd>
            </div>
            <div>
              <dt class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] font-semibold mb-1">Imza Anahtarı (env)</dt>
              <dd class="font-mono text-[10px] text-[var(--color-text-soft)]">{p.secretEnv}</dd>
            </div>
            <div>
              <dt class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] font-semibold mb-1">Satıcı Paneli</dt>
              <dd>
                <a href={p.docsLink} target="_blank" rel="noopener" class="text-[10px] text-[var(--color-primary)] hover:underline">
                  {p.docsLink} ↗
                </a>
              </dd>
            </div>
          </dl>

          {!p.enabled && (
            <div class="mt-3 p-2 rounded-lg bg-amber-500/10 border border-amber-500/20 text-[10px] text-amber-300">
              ⚠ Webhook secret env'de tanımlı değil. Coolify'dan <code class="bg-[var(--color-surface-2)] px-1 rounded">{p.secretEnv}</code> ekleyin ve restart yapın.
            </div>
          )}

          {/* Trendyol API aksiyon butonları */}
          {p.key === 'trendyol' && (
            <div class="mt-4 pt-4 border-t border-[var(--color-border)]/40">
              <div class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] font-semibold mb-2">API Aksiyonları</div>
              <div class="grid grid-cols-3 gap-2">
                <button data-ty-action="test" class="px-3 py-2 rounded-lg bg-[var(--color-surface-2)] hover:bg-[var(--color-border)]/40 text-[11px] font-semibold transition-colors">
                  🔌 Bağlantı Testi
                </button>
                <button data-ty-action="register-webhook" class="px-3 py-2 rounded-lg bg-[var(--color-primary)]/15 hover:bg-[var(--color-primary)]/25 text-[var(--color-primary)] text-[11px] font-semibold transition-colors border border-[var(--color-primary)]/30">
                  🔔 Webhook Kaydet
                </button>
                <button data-ty-action="sync" class="px-3 py-2 rounded-lg bg-[var(--color-surface-2)] hover:bg-[var(--color-border)]/40 text-[11px] font-semibold transition-colors">
                  ⬇ Son 24s Çek
                </button>
              </div>
              <div class="mt-3 pt-3 border-t border-[var(--color-border)]/40">
                <div class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] font-semibold mb-2">Test &amp; Simülasyon</div>
                <div class="grid grid-cols-2 gap-2">
                  <a
                    href="/admin/entegrasyonlar/eslestirme"
                    class="px-3 py-2 rounded-lg bg-[var(--color-surface-2)] hover:bg-[var(--color-border)]/40 text-center text-[11px] font-semibold transition-colors"
                  >
                    🔗 Ürün Eşleştirme
                  </a>
                  <button
                    data-ty-action="simulate"
                    class="px-3 py-2 rounded-lg bg-orange-500/15 hover:bg-orange-500/25 text-orange-300 text-[11px] font-semibold transition-colors border border-orange-500/30"
                  >
                    🧪 Test Sipariş Üret
                  </button>
                </div>
              </div>
              <div id="ty-action-result" class="mt-2 text-[11px] hidden"></div>
            </div>
          )}
        </section>
      ))}
    </div>

    {/* Trendyol kurulum rehberi */}
    <section class="mb-8 p-5 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60">
      <h2 class="font-display font-semibold text-base mb-4">📋 Trendyol Kurulum Adımları</h2>
      <ol class="space-y-3 text-sm text-[var(--color-text-soft)]">
        <li class="flex gap-3">
          <span class="size-6 grid place-items-center rounded-full bg-[var(--color-primary)] text-[var(--color-bg)] text-xs font-bold shrink-0">1</span>
          <div>
            <div class="font-semibold text-[var(--color-text)]">Partner portal'a giriş</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-0.5">
              <a href="https://partner.trendyol.com" target="_blank" class="text-[var(--color-primary)] hover:underline">partner.trendyol.com</a> → Hesabım → Hesap Bilgileri → Entegrasyon Bilgileri
            </div>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="size-6 grid place-items-center rounded-full bg-[var(--color-primary)] text-[var(--color-bg)] text-xs font-bold shrink-0">2</span>
          <div>
            <div class="font-semibold text-[var(--color-text)]">Cari ID, API Key ve Secret'ı al</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-0.5">Coolify'da bu env'leri ekle:</div>
            <div class="mt-1 grid grid-cols-1 gap-1 text-[10px] font-mono text-[var(--color-text-soft)]">
              <code class="bg-[var(--color-surface-2)] px-2 py-1 rounded">TRENDYOL_SUPPLIER_ID = ...</code>
              <code class="bg-[var(--color-surface-2)] px-2 py-1 rounded">TRENDYOL_API_KEY = ...</code>
              <code class="bg-[var(--color-surface-2)] px-2 py-1 rounded">TRENDYOL_API_SECRET = ...</code>
              <code class="bg-[var(--color-surface-2)] px-2 py-1 rounded">TRENDYOL_WEBHOOK_SECRET = ...</code>
            </div>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="size-6 grid place-items-center rounded-full bg-[var(--color-primary)] text-[var(--color-bg)] text-xs font-bold shrink-0">3</span>
          <div>
            <div class="font-semibold text-[var(--color-text)]">Webhook URL'i Trendyol'a kayıt et</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-0.5">
              Trendyol panelinde → Webhook Yönetimi → Yeni Webhook
              <ul class="mt-1.5 ml-4 space-y-0.5 list-disc">
                <li>URL: yukarıdaki Webhook URL'sini yapıştır</li>
                <li>Olaylar: <strong>OrderCreated</strong>, <strong>OrderStatusChanged</strong>, <strong>OrderPackageCreated</strong></li>
                <li>İmza tipi: <strong>HMAC-SHA256</strong></li>
                <li>Webhook secret: yukarıdaki <code class="text-[10px] bg-[var(--color-surface-2)] px-1 rounded">TRENDYOL_WEBHOOK_SECRET</code> ile aynı</li>
              </ul>
            </div>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="size-6 grid place-items-center rounded-full bg-[var(--color-primary)] text-[var(--color-bg)] text-xs font-bold shrink-0">4</span>
          <div>
            <div class="font-semibold text-[var(--color-text)]">Ürün eşleştirmelerini ekle</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-0.5">
              Trendyol'da yayınladığınız her ürünün barkodu/SKU'sunu Carmat ürün konfigürasyonuna eşleyin.
              <a href="/admin/entegrasyonlar/eslestirme" class="text-[var(--color-primary)] underline ml-1">Eşleştirme Sayfası →</a>
            </div>
          </div>
        </li>
        <li class="flex gap-3">
          <span class="size-6 grid place-items-center rounded-full bg-[var(--color-primary)] text-[var(--color-bg)] text-xs font-bold shrink-0">5</span>
          <div>
            <div class="font-semibold text-[var(--color-text)]">Test siparişi oluştur</div>
            <div class="text-xs text-[var(--color-text-muted)] mt-0.5">
              Trendyol'dan kendi mağazanızdan test sipariş ver. Aşağıdaki "Son Webhook'lar" listesinde görünmeli.
            </div>
          </div>
        </li>
      </ol>
    </section>

    {/* Webhook events */}
    <section class="rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 overflow-hidden">
      <div class="p-5 border-b border-[var(--color-border)]/60 flex items-center justify-between">
        <div>
          <h2 class="font-display font-semibold text-base">Son Webhook Olayları</h2>
          <p class="text-[11px] text-[var(--color-text-muted)] mt-0.5">{events.length} kayıt (son 50)</p>
        </div>
      </div>
      {events.length === 0 ? (
        <div class="p-8 text-center text-xs text-[var(--color-text-muted)]">
          Henüz webhook gelmedi.<br/>
          Kurulum tamamlandığında ve Trendyol'dan ilk sipariş geldiğinde burada görünür.
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] border-b border-[var(--color-border)]/40">
              <tr>
                <th class="px-4 py-3 text-left font-semibold">Tarih</th>
                <th class="px-4 py-3 text-left font-semibold">Platform</th>
                <th class="px-4 py-3 text-left font-semibold">Durum</th>
                <th class="px-4 py-3 text-left font-semibold">Dış ID</th>
                <th class="px-4 py-3 text-left font-semibold">Sipariş No</th>
                <th class="px-4 py-3 text-left font-semibold">Mesaj</th>
              </tr>
            </thead>
            <tbody>
              {events.map((e) => (
                <tr class="border-b border-[var(--color-border)]/30 hover:bg-[var(--color-surface-2)]/40">
                  <td class="px-4 py-3 text-xs text-[var(--color-text-muted)] whitespace-nowrap">{formatDateTime(e.receivedAt)}</td>
                  <td class="px-4 py-3 text-xs uppercase">{e.platform}</td>
                  <td class="px-4 py-3">
                    <span class={`px-2 py-0.5 rounded-full text-[10px] font-semibold border ${STATUS_COLOR[e.status] ?? ''}`}>
                      {STATUS_LABEL[e.status] ?? e.status}
                    </span>
                  </td>
                  <td class="px-4 py-3 font-mono text-[10px] text-[var(--color-text-soft)]">{e.externalId ?? '—'}</td>
                  <td class="px-4 py-3">
                    {e.orderNo ? (
                      <a href={`/admin/orders/${e.orderNo}`} class="font-mono text-[10px] text-[var(--color-primary)] hover:underline">{e.orderNo}</a>
                    ) : <span class="text-[10px] text-[var(--color-text-muted)]">—</span>}
                  </td>
                  <td class="px-4 py-3 text-xs text-[var(--color-text-soft)] truncate max-w-md">{e.message ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  </div>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.copy-url-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const url = btn.dataset.url
        if (!url) return
        try {
          await navigator.clipboard.writeText(url)
          const orig = btn.textContent
          btn.textContent = '✓ Kopyalandı'
          setTimeout(() => { btn.textContent = orig }, 1500)
        } catch {}
      })
    })

    // Trendyol API aksiyon butonları
    const resultBox = document.getElementById('ty-action-result')
    function showResult(html: string, kind: 'ok' | 'err' | 'info' = 'info') {
      if (!resultBox) return
      const palette =
        kind === 'ok'
          ? 'bg-emerald-500/10 border-emerald-500/30 text-emerald-300'
          : kind === 'err'
          ? 'bg-red-500/10 border-red-500/30 text-red-300'
          : 'bg-[var(--color-surface-2)] border-[var(--color-border)]/40 text-[var(--color-text-soft)]'
      resultBox.className = `mt-2 text-[11px] p-2 rounded-lg border ${palette}`
      resultBox.classList.remove('hidden')
      resultBox.innerHTML = html
    }

    document.querySelectorAll<HTMLButtonElement>('[data-ty-action]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const action = btn.dataset.tyAction
        const orig = btn.textContent
        btn.disabled = true
        btn.textContent = '⏳ Çalışıyor...'
        showResult('İstek gönderiliyor…', 'info')

        try {
          if (action === 'test') {
            const res = await fetch('/api/integrations/trendyol/test', { method: 'POST' })
            const data = await res.json()
            if (data.ok) showResult(`✓ ${data.message}`, 'ok')
            else showResult(`✗ ${data.message}`, 'err')
          } else if (action === 'register-webhook') {
            if (!confirm("Trendyol panelinde Carmat webhook'u kaydedilsin mi?\n\nNot: TRENDYOL_WEBHOOK_SECRET env'i tanımlı değilse imzasız webhook olarak kaydolur.")) {
              btn.disabled = false; btn.textContent = orig; return
            }
            const res = await fetch('/api/integrations/trendyol/webhooks', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({}),
            })
            const data = await res.json()
            if (data.ok) {
              showResult(`✓ Webhook kaydedildi: <code>${data.registeredUrl}</code><br/>id: ${data.webhook?.id ?? '—'}`, 'ok')
            } else {
              showResult(`✗ Hata: ${data.error}`, 'err')
            }
          } else if (action === 'sync') {
            const res = await fetch('/api/integrations/trendyol/sync', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ sinceHours: 24 }),
            })
            const data = await res.json()
            if (data.ok) {
              showResult(`✓ ${data.imported} yeni · ${data.skipped} mevcut · ${data.failed} hata (son ${data.sinceHours}s)`, 'ok')
              if (data.imported > 0) setTimeout(() => location.reload(), 1500)
            } else {
              showResult(`✗ ${data.error}`, 'err')
            }
          } else if (action === 'simulate') {
            if (!confirm('Sahte Trendyol siparişi oluşturulsun mu?\n\nBu sadece test amaçlıdır — gerçek bir müşteri değildir. Sonradan elle silebilirsiniz.')) {
              btn.disabled = false; btn.textContent = orig; return
            }
            const res = await fetch('/api/integrations/trendyol/simulate', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({}),
            })
            const data = await res.json()
            if (data.ok) {
              showResult(`✓ Sipariş oluşturuldu: <a class="underline font-semibold" href="/admin/orders/${data.orderNo}">${data.orderNo}</a> · External ID: <code>${data.externalId}</code>`, 'ok')
            } else {
              showResult(`✗ Hata: ${data.message || data.error}`, 'err')
            }
          }
        } catch (e) {
          showResult(`✗ Beklenmedik hata: ${(e as Error).message}`, 'err')
        } finally {
          btn.disabled = false
          btn.textContent = orig
        }
      })
    })
  </script>
</AdminLayout>
