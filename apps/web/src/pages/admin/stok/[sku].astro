---
export const prerender = false
import AdminLayout from '@layouts/AdminLayout.astro'
import { getSession } from '../../../server/auth'
import { getStockBySku, listMovements } from '../../../server/stock'
import { formatDateTime } from '@lib/format'

if (!getSession(Astro.cookies)) return Astro.redirect('/admin/login')

const sku = Astro.params.sku!
const item = getStockBySku(sku)
if (!item) return new Response('Stok bulunamadı', { status: 404 })

const movements = listMovements({ sku }).slice(0, 100)
const isCritical = item.qty <= item.criticalThreshold

const REASON_LABELS: Record<string, string> = {
  order_consume: 'Sipariş tüketim',
  manual_in: 'Mal alımı',
  manual_out: 'Manuel çıkış',
  fire: 'Fire',
  count_fix: 'Sayım düzeltme',
}
---

<AdminLayout title={item.label} current="stock">
  <div class="p-4 md:p-10 max-w-5xl mx-auto">
    <a href="/admin/stok" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-primary)]">← Stok listesi</a>

    <header class="mt-3 mb-6 flex items-end justify-between gap-4 flex-wrap">
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-primary)] font-semibold">SKU</p>
        <h1 class="mt-1 font-display text-2xl font-semibold">{item.label}</h1>
        <div class="mt-1 font-mono text-[10px] text-[var(--color-text-muted)]">{item.sku}</div>
      </div>
      <div class={['px-4 py-3 rounded-xl border', isCritical ? 'border-red-500/40 bg-red-500/10' : 'border-emerald-500/30 bg-emerald-500/10'].join(' ')}>
        <div class="text-[10px] uppercase tracking-wider font-semibold opacity-70">Mevcut Stok</div>
        <div class={['mt-0.5 font-display text-3xl font-semibold tabular-nums', isCritical ? 'text-red-400' : 'text-emerald-400'].join(' ')}>
          {item.qty.toFixed(item.unit === 'piece' ? 0 : 2)} <span class="text-base font-normal">{item.unit === 'meter' ? 'm' : item.unit === 'kg' ? 'kg' : 'ad'}</span>
        </div>
        <div class="mt-1 text-[10px] text-[var(--color-text-soft)]">Kritik eşik: {item.criticalThreshold}</div>
      </div>
    </header>

    {/* Manuel düzeltme formu */}
    <section class="rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 p-5 mb-6">
      <h2 class="font-display font-semibold text-base mb-4">Stok Düzeltme</h2>

      <div class="grid md:grid-cols-2 gap-4">
        {/* Mal alımı / çıkış */}
        <div class="space-y-2">
          <h3 class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider">Hareket Ekle</h3>
          <form id="adjustForm" class="space-y-2">
            <div class="grid grid-cols-2 gap-2">
              <select name="reason" class="px-3 py-2 rounded-lg bg-[var(--color-surface-2)] border border-[var(--color-border)] focus:border-[var(--color-primary)] outline-none text-sm">
                <option value="manual_in">Mal alımı (+)</option>
                <option value="manual_out">Manuel çıkış (−)</option>
                <option value="fire">Fire (−)</option>
              </select>
              <input name="delta" type="number" step="any" placeholder="Miktar" required class="px-3 py-2 rounded-lg bg-[var(--color-surface-2)] border border-[var(--color-border)] focus:border-[var(--color-primary)] outline-none text-sm" />
            </div>
            <input name="note" type="text" placeholder="Not (opsiyonel)" class="w-full px-3 py-2 rounded-lg bg-[var(--color-surface-2)] border border-[var(--color-border)] focus:border-[var(--color-primary)] outline-none text-sm" />
            <button type="submit" class="w-full px-4 py-2 rounded-lg text-sm font-semibold bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-[var(--color-bg)]">Hareket Kaydet</button>
          </form>
        </div>

        {/* Sayım modu */}
        <div class="space-y-2">
          <h3 class="text-xs font-semibold text-[var(--color-text-muted)] uppercase tracking-wider">Sayım (Yeniden Belirle)</h3>
          <form id="countForm" class="space-y-2">
            <input name="setQty" type="number" step="any" min="0" placeholder={`Yeni miktar (mevcut: ${item.qty})`} required class="w-full px-3 py-2 rounded-lg bg-[var(--color-surface-2)] border border-[var(--color-border)] focus:border-[var(--color-primary)] outline-none text-sm" />
            <input name="note" type="text" placeholder="Not (opsiyonel)" class="w-full px-3 py-2 rounded-lg bg-[var(--color-surface-2)] border border-[var(--color-border)] focus:border-[var(--color-primary)] outline-none text-sm" />
            <button type="submit" class="w-full px-4 py-2 rounded-lg text-sm font-semibold border border-[var(--color-border)] hover:bg-[var(--color-surface-2)]">Sayımı Kaydet</button>
            <p class="text-[10px] text-[var(--color-text-muted)]">Fiziksel sayım sonrası gerçek miktarı girin.</p>
          </form>
        </div>
      </div>

      <p id="adjustMsg" class="hidden mt-3 text-xs"></p>
    </section>

    {/* Hareket geçmişi */}
    <section class="rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 overflow-hidden">
      <div class="p-5 border-b border-[var(--color-border)]/60">
        <h2 class="font-display font-semibold text-base">Hareket Geçmişi</h2>
        <p class="text-[11px] text-[var(--color-text-muted)] mt-0.5">{movements.length} hareket gösteriliyor</p>
      </div>
      {movements.length === 0 ? (
        <div class="p-8 text-center text-xs text-[var(--color-text-muted)]">Bu SKU için henüz hareket yok.</div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] border-b border-[var(--color-border)]/40">
              <tr>
                <th class="px-4 py-3 text-left font-semibold">Tarih</th>
                <th class="px-4 py-3 text-left font-semibold">Sebep</th>
                <th class="px-4 py-3 text-left font-semibold">Sipariş</th>
                <th class="px-4 py-3 text-right font-semibold">Hareket</th>
                <th class="px-4 py-3 text-left font-semibold">Aktör</th>
                <th class="px-4 py-3 text-left font-semibold">Not</th>
              </tr>
            </thead>
            <tbody>
              {movements.map((m) => (
                <tr class="border-b border-[var(--color-border)]/30">
                  <td class="px-4 py-3 text-xs text-[var(--color-text-muted)] whitespace-nowrap">{formatDateTime(m.at)}</td>
                  <td class="px-4 py-3 text-xs">{REASON_LABELS[m.reason] ?? m.reason}</td>
                  <td class="px-4 py-3">
                    {m.orderNo ? (
                      <a href={`/admin/orders/${m.orderNo}`} class="font-mono text-[10px] text-[var(--color-primary)] hover:underline">{m.orderNo}</a>
                    ) : <span class="text-[10px] text-[var(--color-text-muted)]">—</span>}
                  </td>
                  <td class={['px-4 py-3 text-right font-semibold tabular-nums', m.delta < 0 ? 'text-red-400' : 'text-emerald-400'].join(' ')}>
                    {m.delta > 0 ? `+${m.delta.toFixed(2)}` : m.delta.toFixed(2)}
                  </td>
                  <td class="px-4 py-3 text-xs text-[var(--color-text-muted)]">{m.actor}</td>
                  <td class="px-4 py-3 text-xs text-[var(--color-text-soft)] truncate max-w-xs">{m.note ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>
  </div>

  <script define:vars={{ sku }}>
    const msg = document.getElementById('adjustMsg')
    function showMsg(text, ok) {
      if (!msg) return
      msg.textContent = text
      msg.className = `mt-3 text-xs ${ok ? 'text-emerald-400' : 'text-red-400'}`
    }
    document.getElementById('adjustForm')?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const fd = new FormData(e.target)
      const reason = fd.get('reason')
      let delta = parseFloat(fd.get('delta'))
      if (isNaN(delta)) return showMsg('Miktar gerekli', false)
      // Manuel out / fire için negatif yap
      if ((reason === 'manual_out' || reason === 'fire') && delta > 0) delta = -delta
      const r = await fetch('/api/stock/adjust', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sku, delta, reason, note: fd.get('note') || undefined }),
      })
      if (r.ok) {
        showMsg('Hareket kaydedildi, sayfa yenileniyor…', true)
        setTimeout(() => location.reload(), 800)
      } else {
        showMsg('Hata: ' + await r.text(), false)
      }
    })
    document.getElementById('countForm')?.addEventListener('submit', async (e) => {
      e.preventDefault()
      const fd = new FormData(e.target)
      const setQty = parseFloat(fd.get('setQty'))
      if (isNaN(setQty) || setQty < 0) return showMsg('Geçerli miktar girin', false)
      const r = await fetch('/api/stock/adjust', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ sku, setQty, reason: 'count_fix', note: fd.get('note') || undefined }),
      })
      if (r.ok) {
        showMsg('Sayım kaydedildi, sayfa yenileniyor…', true)
        setTimeout(() => location.reload(), 800)
      } else {
        showMsg('Hata: ' + await r.text(), false)
      }
    })
  </script>
</AdminLayout>
