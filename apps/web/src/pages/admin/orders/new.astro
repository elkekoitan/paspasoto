---
export const prerender = false
import AdminLayout from '@layouts/AdminLayout.astro'
import { getSession } from '../../../server/auth'
import NewOrderForm from '@components/admin/NewOrderForm.tsx'

if (!getSession(Astro.cookies)) return Astro.redirect('/admin/login')
---

<AdminLayout title="Yeni Sipariş" current="new">
  <div class="p-6 md:p-10 max-w-7xl mx-auto">
    <header class="mb-8">
      <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-primary)] font-semibold">Yeni Sipariş</p>
      <h1 class="mt-2 font-display text-3xl font-semibold">Sipariş Ekle</h1>
      <p class="mt-2 text-sm text-[var(--color-text-soft)]">
        Müşteri WhatsApp / telefon yoluyla sipariş verdi mi? Detayları aşağıdan girin, sistemimize kaydedip takip linki üretin.
      </p>
    </header>
    <NewOrderForm client:load />
  </div>
</AdminLayout>
