---
export const prerender = false
import AdminLayout from '@layouts/AdminLayout.astro'
import { getCurrentUser } from '../../server/auth'
import { listOrders, PRODUCTION_TIMELINE, PAYMENT_METHOD_LABELS, type OrderStatus } from '../../server/db'
import { listUsers } from '../../server/users'
import { formatTRY, formatDateTime } from '@lib/format'

const me = getCurrentUser(Astro.cookies)
if (!me) return Astro.redirect('/admin/login')
// Personel kullanıcı kendi dashboard'una yönlendirilir
if (me.role === 'staff') return Astro.redirect('/admin/personel')

const orders = listOrders()
const allUsers = listUsers()
const staffUsers = allUsers.filter((u) => u.role === 'staff' && u.active)
const now = Date.now()
const day = 24 * 60 * 60 * 1000

const totalRevenue = orders.reduce((s, o) => s + o.total, 0)
const paidRevenue = orders.reduce((s, o) => s + o.paidAmount, 0)
const remainingRevenue = totalRevenue - paidRevenue

const last7 = orders.filter((o) => now - o.createdAt < 7 * day)
const last30 = orders.filter((o) => now - o.createdAt < 30 * day)
const revenueLast30 = last30.reduce((s, o) => s + o.total, 0)
const revenueLast7 = last7.reduce((s, o) => s + o.total, 0)

const inProductionCount = orders.filter(
  (o) => o.productionStatus === 'in_production' || o.productionStatus === 'received',
).length
const readyCount = orders.filter((o) => o.productionStatus === 'ready').length
const deliveredCount = orders.filter((o) => o.productionStatus === 'delivered').length
const awaitingPaymentCount = orders.filter(
  (o) => o.paymentStatus !== 'tamamlandi' && o.productionStatus !== 'cancelled',
).length

/* Top brands (adet) */
const brandTally = new Map<string, { slug: string; name: string; count: number; revenue: number }>()
for (const o of orders) {
  for (const it of o.items) {
    const prev = brandTally.get(it.brandSlug) ?? { slug: it.brandSlug, name: it.brandName, count: 0, revenue: 0 }
    prev.count += it.qty
    prev.revenue += (it.unitPrice ?? 0) * it.qty
    brandTally.set(it.brandSlug, prev)
  }
}
const topBrands = [...brandTally.values()].sort((a, b) => b.count - a.count).slice(0, 5)

/* Renkler */
const matTally = new Map<string, { name: string; count: number }>()
const borderTally = new Map<string, { name: string; count: number }>()
for (const o of orders) {
  for (const it of o.items) {
    const m = matTally.get(it.matSlug) ?? { name: it.matName, count: 0 }
    m.count += it.qty
    matTally.set(it.matSlug, m)
    const b = borderTally.get(it.borderSlug) ?? { name: it.borderName, count: 0 }
    b.count += it.qty
    borderTally.set(it.borderSlug, b)
  }
}
const topMats = [...matTally.values()].sort((a, b) => b.count - a.count).slice(0, 5)
const topBorders = [...borderTally.values()].sort((a, b) => b.count - a.count).slice(0, 5)

/* Üretim aşamaları */
const stageTally = PRODUCTION_TIMELINE.map((t) => ({
  status: t.status,
  label: t.label,
  count: orders.filter((o) => o.productionStatus === t.status).length,
}))

/* Kanal dağılımı — Trendyol vs Online vs Manuel */
const CHANNEL_META: Record<string, { label: string; emoji: string; color: string }> = {
  configurator: { label: 'Online (Site)', emoji: '🛒', color: 'bg-blue-500' },
  manual: { label: 'Manuel (Tel/WhatsApp)', emoji: '✋', color: 'bg-zinc-500' },
  physical_store: { label: 'Dükkân', emoji: '🏪', color: 'bg-purple-500' },
  trendyol: { label: 'Trendyol', emoji: '🟠', color: 'bg-orange-500' },
  hepsiburada: { label: 'Hepsiburada', emoji: '🟧', color: 'bg-amber-500' },
  n11: { label: 'n11', emoji: '🟣', color: 'bg-violet-500' },
  woocommerce: { label: 'WooCommerce', emoji: '🟢', color: 'bg-emerald-500' },
  shopify: { label: 'Shopify', emoji: '🟩', color: 'bg-green-500' },
}
const channelTally = new Map<string, { count: number; revenue: number; paid: number }>()
for (const o of orders) {
  const ch = o.channel ?? 'manual'
  const prev = channelTally.get(ch) ?? { count: 0, revenue: 0, paid: 0 }
  prev.count += 1
  prev.revenue += o.total
  prev.paid += o.paidAmount
  channelTally.set(ch, prev)
}
const channelList = [...channelTally.entries()]
  .map(([k, v]) => ({
    key: k,
    label: CHANNEL_META[k]?.label ?? k,
    emoji: CHANNEL_META[k]?.emoji ?? '📦',
    color: CHANNEL_META[k]?.color ?? 'bg-zinc-500',
    ...v,
  }))
  .sort((a, b) => b.revenue - a.revenue)
const maxChannelRevenue = Math.max(1, ...channelList.map((c) => c.revenue))
const marketplaceCount = orders.filter((o) => ['trendyol', 'hepsiburada', 'n11', 'shopify', 'woocommerce'].includes(o.channel ?? '')).length
const marketplaceRevenue = orders.filter((o) => ['trendyol', 'hepsiburada', 'n11', 'shopify', 'woocommerce'].includes(o.channel ?? '')).reduce((s, o) => s + o.total, 0)

/* Ortalama sepet değeri */
const avgOrderValue = orders.length > 0 ? totalRevenue / orders.length : 0
const avgOrderValue30d = last30.length > 0 ? revenueLast30 / last30.length : 0

/* Ödeme yöntemi */
const methodTally = new Map<string, number>()
for (const o of orders) methodTally.set(o.paymentMethod, (methodTally.get(o.paymentMethod) ?? 0) + 1)
const methodList = [...methodTally.entries()]
  .map(([k, v]) => ({ key: k, label: PAYMENT_METHOD_LABELS[k as keyof typeof PAYMENT_METHOD_LABELS] ?? k, count: v }))
  .sort((a, b) => b.count - a.count)

/* Personel performansı — bu ay */
const staffPerformance = staffUsers.map((u) => {
  const myOrders = last30.filter((o) => o.createdBy === u.id)
  return {
    id: u.id,
    username: u.username,
    displayName: u.displayName,
    orderCount: myOrders.length,
    revenue: myOrders.reduce((s, o) => s + o.total, 0),
    lastLoginAt: u.lastLoginAt,
  }
}).sort((a, b) => b.revenue - a.revenue)
const maxStaffRevenue = Math.max(1, ...staffPerformance.map((s) => s.revenue))

/* Müşteriler */
const customers = new Map<string, { name: string; phone: string; orderCount: number; total: number }>()
for (const o of orders) {
  const k = (o.customer.phone || o.customer.fullName).replace(/\s+/g, '')
  const prev = customers.get(k) ?? { name: o.customer.fullName, phone: o.customer.phone, orderCount: 0, total: 0 }
  prev.orderCount += 1
  prev.total += o.total
  customers.set(k, prev)
}
const customerList = [...customers.values()]
const repeatCustomers = customerList.filter((c) => c.orderCount > 1).length
const topCustomers = customerList.sort((a, b) => b.total - a.total).slice(0, 5)

const statusLabel = (s: OrderStatus) =>
  PRODUCTION_TIMELINE.find((t) => t.status === s)?.label ?? s

const STATUS_CHIP: Record<string, string> = {
  received: 'bg-blue-500/15 text-blue-400 border-blue-500/30',
  in_production: 'bg-amber-500/15 text-amber-400 border-amber-500/30',
  ready: 'bg-cyan-500/15 text-cyan-400 border-cyan-500/30',
  delivered: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30',
  cancelled: 'bg-red-500/15 text-red-400 border-red-500/30',
  // Legacy
  payment_confirmed: 'bg-amber-500/15 text-amber-400 border-amber-500/30',
  production_started: 'bg-amber-500/15 text-amber-400 border-amber-500/30',
  production_cutting: 'bg-amber-500/15 text-amber-400 border-amber-500/30',
  production_sewing: 'bg-amber-500/15 text-amber-400 border-amber-500/30',
  quality_check: 'bg-amber-500/15 text-amber-400 border-amber-500/30',
  ready_pickup: 'bg-cyan-500/15 text-cyan-400 border-cyan-500/30',
  shipped: 'bg-cyan-500/15 text-cyan-400 border-cyan-500/30',
  picked_up: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30',
}
const PAYMENT_CHIP: Record<string, string> = {
  bekliyor: 'bg-amber-500/15 text-amber-400 border-amber-500/30',
  kismi: 'bg-blue-500/15 text-blue-400 border-blue-500/30',
  tamamlandi: 'bg-emerald-500/15 text-emerald-400 border-emerald-500/30',
  iade: 'bg-red-500/15 text-red-400 border-red-500/30',
}

const maxBrandCount = Math.max(1, ...topBrands.map((b) => b.count))
const maxMatCount = Math.max(1, ...topMats.map((m) => m.count))
const maxBorderCount = Math.max(1, ...topBorders.map((m) => m.count))
const maxMethodCount = Math.max(1, ...methodList.map((m) => m.count))
const maxStageCount = Math.max(1, ...stageTally.map((s) => s.count))

const paidPercent = totalRevenue ? Math.round((paidRevenue / totalRevenue) * 100) : 0
---

<AdminLayout title="Gösterge" current="dashboard">
  <div class="p-6 md:p-10 max-w-7xl mx-auto">
    <header class="flex items-end justify-between gap-4 mb-8 flex-wrap animate-in fade-in slide-in-from-top-4 duration-700">
      <div>
        <p class="text-[10px] uppercase tracking-[0.25em] text-[var(--color-primary)] font-bold drop-shadow-[0_0_8px_rgba(var(--color-primary-rgb),0.5)]">
          Carmat Yönetim Sistemi
        </p>
        <h1 class="mt-2 font-display text-4xl font-bold tracking-tight bg-gradient-to-r from-white to-white/60 bg-clip-text text-transparent">Gösterge Paneli</h1>
        <p class="mt-2 text-sm text-[var(--color-text-soft)] font-medium">
          Bu ay <span class="text-white font-semibold">{last30.length}</span> sipariş · <span class="text-white font-semibold">{formatTRY(revenueLast30)}</span> ciro · <span class="text-[var(--color-primary)]">{repeatCustomers}</span> sadık müşteri
        </p>
      </div>
      <a
        href="/admin/orders/new"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-xl text-sm font-bold bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-primary-hover)] text-[var(--color-bg)] transition-all hover:scale-105 hover:shadow-[0_0_20px_rgba(var(--color-primary-rgb),0.4)]"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 5v14M5 12h14"/></svg>
        Yeni Sipariş
      </a>
    </header>

    {/* KPI Row — tıklanınca filtreli sipariş listesine */}
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5 mb-8">
      <a href="/admin/orders" class="p-6 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 hover:border-[var(--color-primary)]/50 hover:-translate-y-1 shadow-lg hover:shadow-[0_10px_30px_rgba(0,0,0,0.5)] transition-all duration-300 group animate-in fade-in slide-in-from-bottom-4 duration-700" style="animation-fill-mode: backwards; animation-delay: 100ms;">
        <div class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)] font-bold flex items-center justify-between">
          Toplam Sipariş
          <span class="text-[var(--color-text-muted)] group-hover:text-[var(--color-primary)] transition-colors opacity-0 group-hover:opacity-100 group-hover:translate-x-1 duration-300">→</span>
        </div>
        <div class="mt-3 font-display text-4xl font-bold tabular-nums tracking-tight">{orders.length}</div>
        <div class="mt-1.5 text-xs text-[var(--color-text-soft)] font-medium">Son 7 gün: <span class="text-white">{last7.length}</span></div>
      </a>
      <a href="/admin/orders?filter=production" class="p-6 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 hover:border-amber-500/50 hover:-translate-y-1 shadow-lg hover:shadow-[0_10px_30px_rgba(245,158,11,0.15)] transition-all duration-300 group animate-in fade-in slide-in-from-bottom-4 duration-700" style="animation-fill-mode: backwards; animation-delay: 200ms;">
        <div class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)] font-bold flex items-center justify-between">
          Üretimde
          <span class="text-[var(--color-text-muted)] group-hover:text-amber-400 transition-colors opacity-0 group-hover:opacity-100 group-hover:translate-x-1 duration-300">→</span>
        </div>
        <div class="mt-3 font-display text-4xl font-bold tabular-nums tracking-tight text-amber-50">{inProductionCount}</div>
        <div class="mt-1.5 text-xs text-[var(--color-text-soft)] font-medium">Hazır: <span class="text-white">{readyCount}</span> · Teslim: <span class="text-white">{deliveredCount}</span></div>
      </a>
      <a href="/admin/orders?filter=unpaid" class="p-6 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 hover:border-blue-500/50 hover:-translate-y-1 shadow-lg hover:shadow-[0_10px_30px_rgba(59,130,246,0.15)] transition-all duration-300 group animate-in fade-in slide-in-from-bottom-4 duration-700" style="animation-fill-mode: backwards; animation-delay: 300ms;">
        <div class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)] font-bold flex items-center justify-between">
          Ödeme Bekliyor
          <span class="text-[var(--color-text-muted)] group-hover:text-blue-400 transition-colors opacity-0 group-hover:opacity-100 group-hover:translate-x-1 duration-300">→</span>
        </div>
        <div class="mt-3 font-display text-4xl font-bold tabular-nums tracking-tight text-blue-50">{awaitingPaymentCount}</div>
        <div class="mt-1.5 text-xs text-[var(--color-text-soft)] font-medium">Açık: <span class="text-white">{formatTRY(remainingRevenue)}</span></div>
      </a>
      <a href="/admin/orders?sort=total-desc" class="p-6 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 hover:border-emerald-500/50 hover:-translate-y-1 shadow-lg hover:shadow-[0_10px_30px_rgba(16,185,129,0.15)] transition-all duration-300 group animate-in fade-in slide-in-from-bottom-4 duration-700" style="animation-fill-mode: backwards; animation-delay: 400ms;">
        <div class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)] font-bold flex items-center justify-between">
          Toplam Ciro
          <span class="text-[var(--color-text-muted)] group-hover:text-emerald-400 transition-colors opacity-0 group-hover:opacity-100 group-hover:translate-x-1 duration-300">→</span>
        </div>
        <div class="mt-3 font-display text-3xl md:text-4xl font-bold tabular-nums tracking-tight text-emerald-50">{formatTRY(totalRevenue)}</div>
        <div class="mt-1.5 text-xs text-[var(--color-text-soft)] font-medium">Tahsilat: <span class="text-white">{formatTRY(paidRevenue)}</span> <span class="text-emerald-400">(%{paidPercent})</span></div>
      </a>
    </div>

    {/* 30/7/% kart üçlüsü — tarih filtreleriyle */}
    <div class="grid md:grid-cols-4 gap-4 mb-10">
      <a href="/admin/orders?range=30" class="p-5 rounded-2xl bg-gradient-to-br from-[var(--color-primary-soft)] to-[var(--color-surface)] border border-[var(--color-primary)]/30 hover:border-[var(--color-primary)] hover:-translate-y-0.5 transition-all group">
        <div class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-primary)] font-semibold flex items-center justify-between">
          Bu Ay (30 gün)
          <span class="opacity-60 group-hover:opacity-100">→</span>
        </div>
        <div class="mt-2 font-display text-2xl md:text-3xl font-semibold">{formatTRY(revenueLast30)}</div>
        <div class="mt-1 text-xs text-[var(--color-text-soft)]">{last30.length} sipariş</div>
      </a>
      <a href="/admin/orders?range=7" class="p-5 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 hover:border-[var(--color-primary)]/40 hover:-translate-y-0.5 transition-all group">
        <div class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)] font-semibold flex items-center justify-between">
          Bu Hafta (7 gün)
          <span class="opacity-60 group-hover:opacity-100">→</span>
        </div>
        <div class="mt-2 font-display text-2xl md:text-3xl font-semibold">{formatTRY(revenueLast7)}</div>
        <div class="mt-1 text-xs text-[var(--color-text-soft)]">{last7.length} sipariş</div>
      </a>
      <div class="p-5 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60">
        <div class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)] font-semibold">
          Ortalama Sepet
        </div>
        <div class="mt-2 font-display text-2xl md:text-3xl font-semibold tabular-nums">{formatTRY(avgOrderValue)}</div>
        <div class="mt-1 text-xs text-[var(--color-text-soft)]">Bu ay: <span class="text-white">{formatTRY(avgOrderValue30d)}</span></div>
      </div>
      <a href="/admin/orders?filter=unpaid" class="p-5 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 hover:border-emerald-500/40 hover:-translate-y-0.5 transition-all group">
        <div class="text-[10px] uppercase tracking-[0.2em] text-[var(--color-text-muted)] font-semibold flex items-center justify-between">
          Tahsilat
          <span class="opacity-60 group-hover:opacity-100">→</span>
        </div>
        <div class="mt-2 font-display text-2xl md:text-3xl font-semibold">%{paidPercent}</div>
        <div class="mt-2 h-2 rounded-full bg-[var(--color-surface-2)] overflow-hidden">
          <div class="h-full bg-gradient-to-r from-emerald-500 to-emerald-400" style={`width: ${paidPercent}%`}></div>
        </div>
        <div class="mt-1 text-xs text-[var(--color-text-soft)]">Açık: {formatTRY(remainingRevenue)}</div>
      </a>
    </div>

    {/* Kanal dağılımı — Trendyol vs Online vs Manuel */}
    {channelList.length > 0 && (
      <section class="mb-10 p-5 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 animate-in fade-in slide-in-from-bottom-4 duration-700">
        <header class="flex items-end justify-between gap-3 mb-4 flex-wrap">
          <div>
            <h3 class="font-display font-semibold text-base">Satış Kanalları</h3>
            <p class="text-[11px] text-[var(--color-text-muted)] mt-0.5">
              {marketplaceCount > 0
                ? `Marketplace: ${marketplaceCount} sipariş · ${formatTRY(marketplaceRevenue)}`
                : 'Henüz marketplace siparişi yok'}
            </p>
          </div>
          <a href="/admin/entegrasyonlar" class="text-xs text-[var(--color-primary)] hover:underline font-semibold">
            Entegrasyonlar →
          </a>
        </header>
        <ul class="space-y-2.5">
          {channelList.map((c) => (
            <li>
              <a href={`/admin/orders?channel=${c.key}`} class="block group">
                <div class="flex items-baseline justify-between mb-1.5">
                  <span class="text-sm font-medium group-hover:text-[var(--color-primary)] transition-colors flex items-center gap-2">
                    <span>{c.emoji}</span>
                    <span>{c.label}</span>
                  </span>
                  <span class="text-[11px] text-[var(--color-text-muted)] tabular-nums">
                    {c.count} sipariş · {formatTRY(c.revenue)}
                  </span>
                </div>
                <div class="h-2 rounded-full bg-[var(--color-surface-2)] overflow-hidden">
                  <div class={`h-full ${c.color}`} style={`width: ${(c.revenue / maxChannelRevenue) * 100}%`}></div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* Analiz panelleri */}
    <div class="grid lg:grid-cols-2 gap-6 mb-12 animate-in fade-in slide-in-from-bottom-8 duration-1000 delay-500" style="animation-fill-mode: backwards;">
      {/* Top Brands */}
      <section class="p-5 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60">
        <header class="mb-4">
          <h3 class="font-display font-semibold text-base">En Çok Satan Markalar</h3>
          <p class="text-[11px] text-[var(--color-text-muted)] mt-0.5">Adet ve gelir bazında</p>
        </header>
        {topBrands.length === 0 ? (
          <p class="text-sm text-[var(--color-text-muted)] text-center py-4">Henüz veri yok</p>
        ) : (
          <ul class="space-y-2.5">
            {topBrands.map((b) => (
              <li>
                <a href={`/admin/orders?brand=${b.slug}`} class="block group">
                  <div class="flex items-baseline justify-between mb-1">
                    <span class="text-sm font-medium group-hover:text-[var(--color-primary)] transition-colors">{b.name}</span>
                    <span class="text-[11px] text-[var(--color-text-muted)] tabular-nums">{b.count} adet · {formatTRY(b.revenue)}</span>
                  </div>
                  <div class="h-2 rounded-full bg-[var(--color-surface-2)] overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-primary-hover)] group-hover:shadow-[0_0_8px_rgba(var(--color-primary-rgb,236,176,85),0.5)]" style={`width: ${(b.count / maxBrandCount) * 100}%`}></div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>

      {/* Üretim aşamaları */}
      <section class="p-5 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60">
        <header class="mb-4">
          <h3 class="font-display font-semibold text-base">Üretim Aşamaları</h3>
          <p class="text-[11px] text-[var(--color-text-muted)] mt-0.5">Aktif siparişlerin dağılımı</p>
        </header>
        {orders.length === 0 ? (
          <p class="text-sm text-[var(--color-text-muted)] text-center py-4">Henüz veri yok</p>
        ) : (
          <ul class="space-y-2">
            {stageTally.map((s) => (
              <li>
                <a href={`/admin/orders?status=${s.status}`} class="flex items-center gap-3 hover:bg-[var(--color-surface-2)]/50 rounded-lg p-1 -m-1 transition-colors">
                  <span class={`px-2 py-0.5 rounded-full text-[10px] font-semibold border whitespace-nowrap min-w-[125px] text-center ${STATUS_CHIP[s.status] ?? ''}`}>
                    {s.label}
                  </span>
                  <div class="flex-1 h-2 rounded-full bg-[var(--color-surface-2)] overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-amber-500 to-amber-400" style={`width: ${(s.count / maxStageCount) * 100}%`}></div>
                  </div>
                  <span class="text-xs tabular-nums text-[var(--color-text-soft)] w-8 text-right">{s.count}</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>

      {/* Mat colors */}
      <section class="p-5 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60">
        <header class="mb-4">
          <h3 class="font-display font-semibold text-base">Popüler Zemin Renkleri</h3>
          <p class="text-[11px] text-[var(--color-text-muted)] mt-0.5">Mat (paspas zemini)</p>
        </header>
        {topMats.length === 0 ? <p class="text-sm text-[var(--color-text-muted)] text-center py-4">Henüz veri yok</p> : (
          <ul class="space-y-2.5">
            {topMats.map((m) => (
              <li>
                <div class="flex items-baseline justify-between mb-1">
                  <span class="text-sm font-medium">{m.name}</span>
                  <span class="text-[11px] text-[var(--color-text-muted)]">{m.count}</span>
                </div>
                <div class="h-2 rounded-full bg-[var(--color-surface-2)] overflow-hidden">
                  <div class="h-full bg-[var(--color-primary)]" style={`width: ${(m.count / maxMatCount) * 100}%`}></div>
                </div>
              </li>
            ))}
          </ul>
        )}
      </section>

      {/* Border colors */}
      <section class="p-5 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60">
        <header class="mb-4">
          <h3 class="font-display font-semibold text-base">Popüler Kenarlık Renkleri</h3>
          <p class="text-[11px] text-[var(--color-text-muted)] mt-0.5">Border</p>
        </header>
        {topBorders.length === 0 ? <p class="text-sm text-[var(--color-text-muted)] text-center py-4">Henüz veri yok</p> : (
          <ul class="space-y-2.5">
            {topBorders.map((m) => (
              <li>
                <div class="flex items-baseline justify-between mb-1">
                  <span class="text-sm font-medium">{m.name}</span>
                  <span class="text-[11px] text-[var(--color-text-muted)]">{m.count}</span>
                </div>
                <div class="h-2 rounded-full bg-[var(--color-surface-2)] overflow-hidden">
                  <div class="h-full bg-cyan-500" style={`width: ${(m.count / maxBorderCount) * 100}%`}></div>
                </div>
              </li>
            ))}
          </ul>
        )}
      </section>

      {/* Payment method */}
      <section class="p-5 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60">
        <header class="mb-4">
          <h3 class="font-display font-semibold text-base">Ödeme Yöntemi Dağılımı</h3>
          <p class="text-[11px] text-[var(--color-text-muted)] mt-0.5">Sipariş bazında</p>
        </header>
        {methodList.length === 0 ? <p class="text-sm text-[var(--color-text-muted)] text-center py-4">Henüz veri yok</p> : (
          <ul class="space-y-2.5">
            {methodList.map((m) => (
              <li>
                <div class="flex items-baseline justify-between mb-1">
                  <span class="text-sm font-medium">{m.label}</span>
                  <span class="text-[11px] text-[var(--color-text-muted)] tabular-nums">{m.count}</span>
                </div>
                <div class="h-2 rounded-full bg-[var(--color-surface-2)] overflow-hidden">
                  <div class="h-full bg-emerald-500" style={`width: ${(m.count / maxMethodCount) * 100}%`}></div>
                </div>
              </li>
            ))}
          </ul>
        )}
      </section>

      {/* Top customers */}
      <section class="p-5 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60">
        <header class="mb-4">
          <h3 class="font-display font-semibold text-base">En Çok Harcayan Müşteriler</h3>
          <p class="text-[11px] text-[var(--color-text-muted)] mt-0.5">{customerList.length} farklı müşteri · {repeatCustomers} tekrar eden</p>
        </header>
        {topCustomers.length === 0 ? <p class="text-sm text-[var(--color-text-muted)] text-center py-4">Henüz veri yok</p> : (
          <ul class="space-y-2">
            {topCustomers.map((c) => (
              <li>
                <a href={`/admin/orders?q=${encodeURIComponent(c.phone)}`} class="flex items-center justify-between gap-3 p-2.5 rounded-lg bg-[var(--color-surface-2)]/50 hover:bg-[var(--color-surface-2)] transition-colors group">
                  <div class="min-w-0">
                    <div class="text-sm font-medium truncate group-hover:text-[var(--color-primary)] transition-colors">{c.name}</div>
                    <div class="text-[10px] text-[var(--color-text-muted)]">{c.phone}</div>
                  </div>
                  <div class="text-right shrink-0">
                    <div class="text-sm font-semibold tabular-nums">{formatTRY(c.total)}</div>
                    <div class="text-[10px] text-[var(--color-text-muted)]">{c.orderCount} sipariş</div>
                  </div>
                </a>
              </li>
            ))}
          </ul>
        )}
      </section>
    </div>

    {/* Personel Performansı (patron için) */}
    <section class="mb-12 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 p-5 md:p-6 animate-in fade-in slide-in-from-bottom-4 duration-700">
      <header class="mb-4 flex items-end justify-between gap-3 flex-wrap">
        <div>
          <h3 class="font-display font-semibold text-base">Personel Performansı (Bu Ay)</h3>
          <p class="text-[11px] text-[var(--color-text-muted)] mt-0.5">Personel başına kestiği sipariş sayısı + toplam ciro</p>
        </div>
        <a href="/admin/patron/personel" class="text-xs text-[var(--color-primary)] hover:underline">
          Personel Yönetimi →
        </a>
      </header>
      {staffPerformance.length === 0 ? (
        <p class="text-sm text-[var(--color-text-muted)] text-center py-6">
          Henüz personel eklenmedi.
          <a href="/admin/patron/personel" class="text-[var(--color-primary)] hover:underline ml-2">Personel Ekle →</a>
        </p>
      ) : (
        <ul class="space-y-3">
          {staffPerformance.map((s) => (
            <li>
              <div class="flex items-baseline justify-between mb-1.5">
                <span class="text-sm font-medium">
                  {s.displayName}
                  <span class="text-[10px] text-[var(--color-text-muted)] ml-1.5">@{s.username}</span>
                </span>
                <span class="text-xs tabular-nums">
                  <span class="text-[var(--color-text-soft)]">{s.orderCount} sipariş</span>
                  <span class="mx-2 text-[var(--color-text-muted)]">·</span>
                  <span class="text-[var(--color-primary)] font-semibold">{formatTRY(s.revenue)}</span>
                </span>
              </div>
              <div class="h-2 rounded-full bg-[var(--color-surface-2)] overflow-hidden">
                <div class="h-full bg-gradient-to-r from-[var(--color-primary)] to-[var(--color-primary-hover)]" style={`width: ${(s.revenue / maxStaffRevenue) * 100}%`}></div>
              </div>
            </li>
          ))}
        </ul>
      )}
    </section>

    {/* Son siparişler */}
    <div class="rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 overflow-hidden shadow-xl animate-in fade-in slide-in-from-bottom-4 duration-1000 delay-700" style="animation-fill-mode: backwards;">
      <div class="flex items-center justify-between p-5 border-b border-[var(--color-border)]/60">
        <h2 class="font-display text-lg font-semibold">Son Siparişler</h2>
        <a href="/admin/orders" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-primary)]">
          Tümünü gör →
        </a>
      </div>
      {orders.length === 0 ? (
        <div class="p-12 text-center">
          <p class="text-[var(--color-text-muted)] mb-4">Henüz sipariş yok.</p>
          <a href="/admin/orders/new" class="text-[var(--color-primary)] hover:underline text-sm">
            İlk siparişi ekleyin →
          </a>
        </div>
      ) : (
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] font-semibold border-b border-[var(--color-border)]/40">
              <tr>
                <th class="px-5 py-3 text-left">Sipariş No</th>
                <th class="px-5 py-3 text-left">Müşteri</th>
                <th class="px-5 py-3 text-left">Araç</th>
                <th class="px-5 py-3 text-left">Tarih</th>
                <th class="px-5 py-3 text-left">Üretim</th>
                <th class="px-5 py-3 text-left">Ödeme</th>
                <th class="px-5 py-3 text-right">Toplam</th>
              </tr>
            </thead>
            <tbody>
              {orders.slice(0, 10).map((o) => (
                <tr
                  data-href={`/admin/orders/${o.orderNo}`}
                  class="border-b border-[var(--color-border)]/30 hover:bg-[var(--color-surface-2)]/60 cursor-pointer transition-colors row-link"
                >
                  <td class="px-5 py-3">
                    <a href={`/admin/orders/${o.orderNo}`} class="font-mono text-xs text-[var(--color-primary)] hover:underline">{o.orderNo}</a>
                  </td>
                  <td class="px-5 py-3">
                    <div class="font-medium">{o.customer.fullName}</div>
                    <div class="text-[10px] text-[var(--color-text-muted)]">{o.customer.phone}</div>
                  </td>
                  <td class="px-5 py-3">
                    {o.items[0] ? (
                      <>
                        <div class="font-medium text-xs">{o.items[0].brandName} {o.items[0].modelName}</div>
                        <div class="text-[10px] text-[var(--color-text-muted)]">{o.items[0].productName}</div>
                      </>
                    ) : '—'}
                  </td>
                  <td class="px-5 py-3 text-xs text-[var(--color-text-muted)] whitespace-nowrap">{formatDateTime(o.createdAt)}</td>
                  <td class="px-5 py-3">
                    <span class={`px-2 py-0.5 rounded-full text-[10px] font-semibold border ${STATUS_CHIP[o.productionStatus] ?? ''}`}>
                      {statusLabel(o.productionStatus)}
                    </span>
                  </td>
                  <td class="px-5 py-3">
                    <span class={`px-2 py-0.5 rounded-full text-[10px] font-semibold border ${PAYMENT_CHIP[o.paymentStatus] ?? ''}`}>
                      {o.paymentStatus === 'bekliyor' ? 'Bekliyor' : o.paymentStatus === 'kismi' ? 'Kısmi' : o.paymentStatus === 'tamamlandi' ? 'Tamamlandı' : 'İade'}
                    </span>
                  </td>
                  <td class="px-5 py-3 text-right font-semibold tabular-nums">{formatTRY(o.total)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </div>

  <script>
    // Tablo satırlarına tıklayınca data-href'e git (link yerine row-level)
    document.querySelectorAll<HTMLElement>('tr.row-link').forEach((row) => {
      row.addEventListener('click', (e) => {
        const target = e.target as HTMLElement
        if (target.closest('a, button')) return
        const href = row.dataset.href
        if (href) window.location.href = href
      })
    })
  </script>
</AdminLayout>
