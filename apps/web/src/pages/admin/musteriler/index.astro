---
export const prerender = false
import AdminLayout from '@layouts/AdminLayout.astro'
import { getCurrentUser } from '../../../server/auth'
import { listCustomers } from '../../../server/customers'
import { formatTRY, formatDateTime } from '@lib/format'

const me = getCurrentUser(Astro.cookies)
if (!me) return Astro.redirect('/admin/login')

const params = Astro.url.searchParams
const segment = params.get('segment') ?? ''
const city = params.get('city') ?? ''
const channel = params.get('channel') ?? ''
const q = (params.get('q') ?? '').toLowerCase()

let customers = listCustomers()
const allCount = customers.length

if (segment) customers = customers.filter((c) => c.segment === segment)
if (city) customers = customers.filter((c) => c.primaryCity === city)
if (channel) customers = customers.filter((c) => c.primaryChannel === channel)
if (q) {
  customers = customers.filter((c) =>
    c.fullName.toLowerCase().includes(q) ||
    c.phone.replace(/\s/g, '').includes(q.replace(/\s/g, '')) ||
    (c.email && c.email.toLowerCase().includes(q))
  )
}

const all = listCustomers()
const segmentCounts = {
  all: allCount,
  vip: all.filter((c) => c.segment === 'vip').length,
  returning: all.filter((c) => c.segment === 'returning').length,
  new: all.filter((c) => c.segment === 'new').length,
  inactive: all.filter((c) => c.segment === 'inactive').length,
  oneTime: all.filter((c) => c.segment === 'one-time').length,
}

const cities = Array.from(new Set(all.map((c) => c.primaryCity).filter(Boolean))).sort() as string[]

const SEGMENT_META: Record<string, { label: string; emoji: string; class: string }> = {
  vip: { label: 'VIP', emoji: '👑', class: 'bg-amber-500/15 text-amber-300 border-amber-500/40' },
  returning: { label: 'Tekrar Eden', emoji: '🔄', class: 'bg-emerald-500/15 text-emerald-300 border-emerald-500/40' },
  new: { label: 'Yeni', emoji: '✨', class: 'bg-blue-500/15 text-blue-300 border-blue-500/40' },
  'one-time': { label: 'Tek Sefer', emoji: '👤', class: 'bg-zinc-500/15 text-zinc-300 border-zinc-500/40' },
  inactive: { label: 'İnaktif', emoji: '💤', class: 'bg-red-500/15 text-red-300 border-red-500/40' },
}
---

<AdminLayout title="Müşteriler" current="dashboard">
  <div class="p-4 md:p-8 max-w-7xl mx-auto">
    <header class="flex items-end justify-between gap-4 mb-6 flex-wrap">
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-primary)] font-semibold">Yönetim</p>
        <h1 class="mt-1 font-display text-2xl md:text-3xl font-bold">👥 Müşteriler</h1>
        <p class="mt-2 text-sm text-[var(--color-text-soft)]">
          {customers.length} müşteri görüntüleniyor ({allCount} toplam)
        </p>
      </div>
    </header>

    {/* Segment chip'leri */}
    <div class="flex flex-wrap gap-2 mb-5">
      {[
        { k: '', l: 'Tümü', n: segmentCounts.all, color: 'bg-[var(--color-primary-soft)]' },
        { k: 'vip', l: '👑 VIP', n: segmentCounts.vip, color: 'bg-amber-500/15' },
        { k: 'returning', l: '🔄 Tekrar Eden', n: segmentCounts.returning, color: 'bg-emerald-500/15' },
        { k: 'new', l: '✨ Yeni', n: segmentCounts.new, color: 'bg-blue-500/15' },
        { k: 'one-time', l: '👤 Tek Sefer', n: segmentCounts.oneTime, color: 'bg-zinc-500/15' },
        { k: 'inactive', l: '💤 İnaktif', n: segmentCounts.inactive, color: 'bg-red-500/15' },
      ].map((s) => (
        <a
          href={s.k ? `/admin/musteriler?segment=${s.k}` : '/admin/musteriler'}
          class={[
            'inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-medium border transition-colors',
            segment === s.k
              ? 'border-[var(--color-primary)] bg-[var(--color-primary-soft)] text-[var(--color-primary)]'
              : 'border-[var(--color-border)] text-[var(--color-text-soft)] hover:text-[var(--color-text)] bg-[var(--color-surface-2)]/40',
          ].join(' ')}
        >
          {s.l}
          <span class="text-[10px] opacity-60">({s.n})</span>
        </a>
      ))}
    </div>

    {/* Filtre + arama */}
    <form method="get" class="mb-5 grid sm:grid-cols-4 gap-2 items-end">
      <input type="hidden" name="segment" value={segment} />
      <label class="sm:col-span-2">
        <div class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] font-semibold mb-1">Ara</div>
        <input
          type="text"
          name="q"
          value={q}
          placeholder="İsim / telefon / e-posta"
          class="w-full px-3 py-2 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)] text-sm"
        />
      </label>
      <label>
        <div class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] font-semibold mb-1">Şehir</div>
        <select name="city" class="w-full px-3 py-2 rounded-lg bg-[var(--color-surface)] border border-[var(--color-border)] text-sm">
          <option value="">Tümü</option>
          {cities.map((c) => <option value={c} selected={city === c}>{c}</option>)}
        </select>
      </label>
      <button type="submit" class="px-4 py-2 rounded-lg text-xs font-semibold bg-[var(--color-primary)] text-black">
        Filtrele
      </button>
    </form>

    {/* Liste */}
    <div class="rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 overflow-hidden">
      {customers.length === 0 ? (
        <div class="p-12 text-center text-[var(--color-text-muted)]">
          Bu filtre ile müşteri yok.
        </div>
      ) : (
        <ul class="divide-y divide-[var(--color-border)]/30">
          {customers.map((c) => {
            const seg = SEGMENT_META[c.segment] ?? SEGMENT_META['one-time']
            return (
              <li>
                <a
                  href={`/admin/musteriler/${encodeURIComponent(c.phoneKey)}`}
                  class="block p-3 md:p-4 hover:bg-[var(--color-surface-2)]/50 transition-colors"
                >
                  <div class="flex items-center gap-3 flex-wrap">
                    <div class="size-10 rounded-full grid place-items-center bg-[var(--color-primary-soft)] text-[var(--color-primary)] font-bold shrink-0">
                      {c.fullName.charAt(0).toUpperCase()}
                    </div>
                    <div class="flex-1 min-w-0">
                      <div class="flex items-center gap-2 flex-wrap">
                        <h3 class="font-semibold text-sm">{c.fullName}</h3>
                        <span class={`px-2 py-0.5 rounded-full text-[9px] font-bold border whitespace-nowrap ${seg.class}`}>
                          {seg.emoji} {seg.label}
                        </span>
                        {c.hasNotes && (
                          <span class="text-[10px] text-[var(--color-text-muted)]" title="Not var">📝</span>
                        )}
                      </div>
                      <div class="text-[11px] text-[var(--color-text-muted)] mt-0.5 flex items-center gap-2 flex-wrap">
                        <span>{c.phone}</span>
                        {c.primaryCity && <span>· {c.primaryCity}</span>}
                        {c.primaryChannel && <span>· {c.primaryChannel}</span>}
                      </div>
                    </div>
                    <div class="text-right">
                      <div class="font-bold text-sm tabular-nums">{formatTRY(c.totalRevenue)}</div>
                      <div class="text-[11px] text-[var(--color-text-muted)]">
                        {c.orderCount} sipariş · Son: {formatDateTime(c.lastOrderAt)}
                      </div>
                    </div>
                  </div>
                </a>
              </li>
            )
          })}
        </ul>
      )}
    </div>
  </div>
</AdminLayout>
