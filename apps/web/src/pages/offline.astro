---
export const prerender = true
import Base from '@layouts/Base.astro'
---

<Base title="Çevrimdışı" description="İnternet bağlantın yok." noindex>
  <section class="container-page py-24 text-center max-w-md mx-auto">
    <div class="size-16 mx-auto grid place-items-center rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)] mb-6 text-3xl">
      📵
    </div>
    <h1 class="font-display text-3xl font-semibold">Çevrimdışısın</h1>
    <p class="mt-3 text-[var(--color-text-soft)]">
      İnternet bağlantın yok gibi görünüyor. Bağlantı kurulduğunda PaspasOto otomatik yüklenecek.
    </p>
    <a
      href="/"
      class="mt-6 inline-flex px-5 py-2.5 rounded-lg text-sm font-semibold border border-[var(--color-border)] hover:border-[var(--color-text-muted)] hover:bg-[var(--color-surface)] transition-colors"
    >
      Yeniden Dene
    </a>
  </section>
</Base>
