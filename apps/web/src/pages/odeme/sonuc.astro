---
export const prerender = false
import Base from '@layouts/Base.astro'

const status = Astro.url.searchParams.get('status') ?? 'failure'
const orderNo = Astro.url.searchParams.get('orderNo') ?? null
const reason = Astro.url.searchParams.get('reason') ?? null

const success = status === 'success'

const reasonText: Record<string, string> = {
  token_missing: 'Ödeme oturumu bulunamadı',
  not_configured: 'Ödeme sistemi henüz aktif değil',
  sdk_error: 'Ödeme servisinde teknik bir sorun oluştu',
}
---

<Base title={success ? 'Ödeme Başarılı' : 'Ödeme Tamamlanamadı'}>
  <section class="container-page py-16 md:py-24">
    <div class="max-w-2xl mx-auto text-center">
      {success ? (
        <>
          <div class="size-24 rounded-full bg-emerald-500/20 grid place-items-center mx-auto ring-2 ring-emerald-500/40">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#10b981" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 6 9 17l-5-5" />
            </svg>
          </div>
          <h1 class="mt-6 font-display text-3xl md:text-5xl font-bold tracking-tight">Ödemeniz Alındı!</h1>
          <p class="mt-4 text-base md:text-lg text-[var(--color-text-soft)] leading-relaxed">
            Siparişiniz onaylandı, atölyemiz <strong class="text-white">aynı gün üretime başlıyor</strong>.
            Tahmini teslimat: <strong class="text-[var(--color-primary)]">2-3 iş günü</strong>.
          </p>
          {orderNo && (
            <div class="mt-8 inline-block px-6 py-4 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60">
              <div class="text-[10px] uppercase tracking-wider text-[var(--color-text-muted)] font-bold">Sipariş No</div>
              <div class="mt-1 font-mono text-xl font-bold text-white">{orderNo}</div>
            </div>
          )}
          <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
            {orderNo && (
              <a
                href={`/siparis-takip/detay?o=${encodeURIComponent(orderNo)}`}
                class="inline-flex items-center justify-center gap-2 px-6 py-3.5 min-h-[56px] rounded-xl bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-black font-bold transition-all"
              >
                Siparişimi Takip Et
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              </a>
            )}
            <a href="/" class="inline-flex items-center justify-center px-6 py-3.5 min-h-[56px] rounded-xl bg-[var(--color-surface)] hover:bg-[var(--color-surface-2)] text-white font-semibold border border-[var(--color-border)]/60 transition-colors">
              Anasayfaya Dön
            </a>
          </div>
        </>
      ) : (
        <>
          <div class="size-24 rounded-full bg-rose-500/20 grid place-items-center mx-auto ring-2 ring-rose-500/40">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#f43f5e" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 6 6 18M6 6l12 12" />
            </svg>
          </div>
          <h1 class="mt-6 font-display text-3xl md:text-5xl font-bold tracking-tight">Ödeme Tamamlanamadı</h1>
          <p class="mt-4 text-base md:text-lg text-[var(--color-text-soft)] leading-relaxed">
            {reason && reasonText[reason] ? reasonText[reason] : 'Ödeme işleminiz tamamlanamadı.'}
          </p>
          <p class="mt-3 text-sm text-[var(--color-text-muted)]">
            Siparişiniz <strong class="text-white">bekleyen ödeme</strong> durumunda; admin sizinle WhatsApp'tan iletişime geçecek
            veya başka bir ödeme yöntemi seçebilirsiniz.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/odeme" class="inline-flex items-center justify-center px-6 py-3.5 min-h-[56px] rounded-xl bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-black font-bold transition-all">
              Tekrar Dene
            </a>
            <a href="https://wa.me/905447108115" target="_blank" rel="noopener" class="inline-flex items-center justify-center gap-2 px-6 py-3.5 min-h-[56px] rounded-xl bg-emerald-500/15 hover:bg-emerald-500/25 text-emerald-400 border border-emerald-500/40 font-semibold transition-colors">
              WhatsApp'tan Yardım Al
            </a>
          </div>
        </>
      )}
    </div>
  </section>
</Base>
