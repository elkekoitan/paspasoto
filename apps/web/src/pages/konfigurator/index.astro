---
export const prerender = false
import Configurator from '@components/configurator/Configurator.tsx'
import '../../styles/globals.css'
---

<!doctype html>
<html lang="tr" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Paspasınızı Tasarlayın — Konfigüratör | PaspasOto</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
      body, html {
        margin: 0;
        padding: 0;
        width: 100%;
        height: 100%;
        overflow: hidden; /* Prevent scrolling, fully immersive */
        background: #000;
        color: #fff;
        font-family: 'Inter', sans-serif;
      }
      /* Hide standard scrollbars */
      ::-webkit-scrollbar { width: 0px; background: transparent; }
    </style>
  </head>
  <body>
    <main class="relative w-full h-[100dvh] overflow-hidden">
      {/* Top transparent minimal nav */}
      <nav class="absolute top-0 inset-x-0 z-50 p-4 md:p-6 flex items-center justify-between gap-3 pointer-events-none">
        <a href="/" class="pointer-events-auto hover:scale-105 transition-transform origin-left">
          <img src="/logo.png" alt="Carmat" class="h-8 md:h-10 w-auto object-contain drop-shadow-[0_4px_12px_rgba(0,0,0,0.8)]" />
        </a>
        {/* Ürün kategorisi geçişi */}
        <div class="pointer-events-auto flex items-center gap-1 p-1 rounded-full bg-black/40 backdrop-blur-md border border-white/15 shadow-lg">
          <span class="px-3 py-1.5 rounded-full bg-white text-black text-[10px] font-bold uppercase tracking-wider">Paspas</span>
          <a href="/konfigurator/koltuk" class="px-3 py-1.5 rounded-full hover:bg-white/15 text-white/80 hover:text-white text-[10px] font-semibold uppercase tracking-wider transition-colors">Koltuk</a>
          <a href="/konfigurator/direksiyon" class="px-3 py-1.5 rounded-full hover:bg-white/15 text-white/80 hover:text-white text-[10px] font-semibold uppercase tracking-wider transition-colors">Direksiyon</a>
        </div>
        <div class="pointer-events-auto">
          <a href="/" class="px-4 py-2 md:px-5 md:py-2.5 rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-md border border-white/20 text-white text-[10px] md:text-xs font-semibold tracking-wider uppercase transition-all shadow-lg hover:shadow-white/10">
            Çıkış
          </a>
        </div>
      </nav>

      {/* Cinematic Configurator */}
      <Configurator client:load />
    </main>
  </body>
</html>
