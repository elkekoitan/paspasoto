---
import Base from '@layouts/Base.astro'
import Configurator from '@components/configurator/Configurator.tsx'
---

<Base
  title="Paspasınızı oluşturun — Konfigüratör"
  description="Marka, model, paspas rengi, kenarlık, topukluk ve amblem seç. 7 adımda paspasınızı tasarlayın, canlı önizleyin ve siparişinizi oluşturmaya başlayın."
>
  <section class="container-page pt-8 pb-20">
    <div class="mb-8 flex items-end justify-between flex-wrap gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-primary)] font-semibold">Konfigüratör</p>
        <h1 class="mt-2 font-display text-3xl md:text-5xl font-semibold tracking-tight leading-[1.05]">
          Paspasınızı <span class="text-gradient-amber">oluşturun</span>.
        </h1>
        <p class="mt-3 text-[var(--color-text-soft)] max-w-xl">
          7 adım, canlı önizleme. Aracınıza özel kombinasyonu siz tasarlayın — atölyemiz üretime başlasın.
        </p>
      </div>
      <a
        href="/galeri"
        class="hidden sm:inline-flex items-center gap-1.5 text-sm font-medium text-[var(--color-text-soft)] hover:text-[var(--color-primary)] transition-colors"
      >
        İlham almak için müşteri galerisi →
      </a>
    </div>

    <Configurator client:load />
  </section>
</Base>
