---
export const prerender = true
import Base from '@layouts/Base.astro'
import SeatCoverConfigurator from '@components/configurator/SeatCoverConfigurator.tsx'
---

<Base
  title="Koltuk Kılıfı Tasarla"
  description="Aracınıza özel koltuk kılıfı — set, malzeme, renk seçin. Atölyemizden net fiyat teklifi için bilgilerinizi gönderin."
>
  <section class="container-page py-10 md:py-16">
    <div class="mb-6">
      <a href="/konfigurator" class="text-xs text-[var(--color-text-muted)] hover:text-[var(--color-primary)]">← Tüm ürünler</a>
      <div class="mt-3 inline-flex items-center gap-2 px-3 py-1 rounded-full bg-[var(--color-primary-soft)] ring-1 ring-[var(--color-primary)]/30">
        <span class="text-[10px] uppercase tracking-[0.2em] font-bold text-[var(--color-primary)]">Yakında · Ön Sipariş</span>
      </div>
      <p class="mt-3 text-sm text-[var(--color-primary)] font-medium uppercase tracking-wider">Koltuk Kılıfı</p>
      <h1 class="mt-2 font-display text-3xl md:text-4xl font-semibold tracking-tight">
        Koltuğunuzu <span class="text-gradient-amber">tasarlayın</span>.
      </h1>
      <p class="mt-2 text-[var(--color-text-soft)] max-w-2xl">
        Aracınıza özel ölçü veya üniversal kalıp · 5 farklı malzeme · 8 renk seçeneği.
        <strong class="text-[var(--color-text)]"> Şu an yalnızca tasarım önizlemesi sunuyoruz</strong> — beğendiğiniz konfigürasyonu bize iletin,
        ön sipariş listesine alalım. Üretim başlayınca size öncelikli haber veririz.
      </p>
    </div>

    <SeatCoverConfigurator client:load />
  </section>
</Base>
