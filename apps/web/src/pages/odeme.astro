---
export const prerender = true
import Base from '@layouts/Base.astro'
import CheckoutForm from '@components/checkout/CheckoutForm.tsx'
---

<Base title="Ödeme — Carmat" description="Sipariş bilgilerinizi tamamlayın ve ödeme yöntemini seçin.">
  <section class="container-page py-10 md:py-16">
    <header class="mb-8">
      <p class="text-sm text-[var(--color-primary)] font-medium uppercase tracking-wider">Ödeme</p>
      <h1 class="mt-2 font-display text-3xl md:text-4xl font-semibold tracking-tight">
        Sipariş bilgilerinizi tamamlayın
      </h1>
    </header>

    <CheckoutForm client:only="preact" />
  </section>
</Base>
