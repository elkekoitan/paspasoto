---
import Base from '@layouts/Base.astro'
import OrderTracker from '@components/tracker/OrderTracker.tsx'
---

<Base title="Sipariş Takip" description="Sipariş numaranız ve telefonunuzun son 4 hanesi ile siparişinizin durumunu sorgulayın.">
  <section class="container-page py-16 md:py-24">
    <div class="max-w-md mx-auto mb-10 text-center">
      <p class="text-xs uppercase tracking-[0.2em] text-[var(--color-primary)] font-semibold">Sipariş Takip</p>
      <h1 class="mt-2 font-display text-3xl md:text-4xl font-semibold tracking-tight">
        Siparişinizi takip edin
      </h1>
      <p class="mt-3 text-[var(--color-text-soft)] text-sm">
        Sipariş numaranız ve telefonunuzun son 4 hanesi ile üretim sürecini canlı izleyin.
      </p>
    </div>
    <OrderTracker client:load />
  </section>
</Base>
