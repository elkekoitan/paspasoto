---
import Base from '@layouts/Base.astro'
---

<Base title="Sipariş Takip" description="Sipariş numaranız ve telefonunuzun son 4 hanesi ile siparişinizin durumunu sorgulayın.">
  <section class="container-page py-16 md:py-24">
    <div class="max-w-md mx-auto">
      <h1 class="font-display text-3xl md:text-4xl font-semibold tracking-tight">Sipariş Takip</h1>
      <p class="mt-3 text-[var(--color-text-soft)]">
        Sipariş numaran ve telefonunun son 4 hanesi ile siparişin durumunu görebilirsin.
      </p>

      <form
        method="POST"
        action="/api/track"
        class="mt-8 p-6 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 space-y-4"
      >
        <div>
          <label for="orderNo" class="block text-sm font-medium mb-1.5">Sipariş Numarası</label>
          <input
            id="orderNo"
            name="orderNo"
            type="text"
            placeholder="PO-260506-A4F2"
            required
            class="w-full px-4 py-2.5 rounded-lg bg-[var(--color-surface-2)] border border-[var(--color-border)] focus:border-[var(--color-primary)] outline-none text-sm font-mono"
          />
        </div>
        <div>
          <label for="phoneLast4" class="block text-sm font-medium mb-1.5">Telefon Son 4 Hane</label>
          <input
            id="phoneLast4"
            name="phoneLast4"
            type="text"
            inputmode="numeric"
            pattern="[0-9]{4}"
            maxlength="4"
            placeholder="1234"
            required
            class="w-full px-4 py-2.5 rounded-lg bg-[var(--color-surface-2)] border border-[var(--color-border)] focus:border-[var(--color-primary)] outline-none text-sm font-mono"
          />
        </div>
        <button
          type="submit"
          class="w-full px-5 py-3 rounded-lg text-sm font-semibold bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-[var(--color-bg)] transition-colors"
        >
          Siparişi Sorgula
        </button>
      </form>

      <p class="mt-6 text-xs text-[var(--color-text-muted)] text-center">
        Sipariş numaranı bulamıyor musun? <a href="https://wa.me/905550000000" class="text-[var(--color-primary)] hover:underline">WhatsApp</a>'tan ulaş.
      </p>
    </div>
  </section>
</Base>
