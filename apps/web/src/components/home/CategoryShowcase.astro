---
/**
 * CategoryShowcase — 5 büyük kategori kartı (paspas + 4 simple).
 * Paspas büyük (col-span-2 desktop), diğerleri normal.
 */
import { CATEGORY_META, ALL_SIMPLE_PRODUCTS } from '@lib/catalog-extra'

const cats = [
  {
    name: 'Aracına Özel Paspas',
    description: 'Lazer ölçü ile birebir, 10 renk + 15 kenarlık seçeneği',
    emoji: '🚗',
    href: '/konfigurator',
    cta: 'Tasarla',
    image: '/assets/mats/hero/default.webp',
    primary: true,
  },
  {
    ...CATEGORY_META['screen-protector'],
    cta: 'Keşfet',
    count: ALL_SIMPLE_PRODUCTS.filter((p) => p.category === 'screen-protector').length,
  },
  {
    ...CATEGORY_META.perfume,
    cta: 'Keşfet',
    count: ALL_SIMPLE_PRODUCTS.filter((p) => p.category === 'perfume').length,
  },
  {
    ...CATEGORY_META.chemical,
    cta: 'Keşfet',
    count: ALL_SIMPLE_PRODUCTS.filter((p) => p.category === 'chemical').length,
  },
  {
    ...CATEGORY_META.bag,
    cta: 'Keşfet',
    count: ALL_SIMPLE_PRODUCTS.filter((p) => p.category === 'bag').length,
  },
]
---

<section class="bg-[var(--color-surface)]/30 py-12 md:py-16 border-y border-[var(--color-border)]/40">
  <div class="container-page">
    <header class="text-center mb-8 md:mb-12">
      <span class="text-[11px] uppercase tracking-[0.2em] text-[var(--color-primary)] font-bold">5 Kategori</span>
      <h2 class="mt-2 font-display text-3xl md:text-5xl font-bold tracking-tight">
        Aracın için her şey
      </h2>
      <p class="mt-3 text-base text-[var(--color-text-soft)] max-w-2xl mx-auto">
        Paspastan parfüme, çantadan kimyasala — tek noktadan profesyonel kalite.
      </p>
    </header>

    {/* 5 kategori grid: paspas col-span-2 desktop, diğerleri 1 */}
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 md:gap-5">
      {cats.map((cat, i) => (
        <a
          href={cat.href}
          class={[
            'group relative overflow-hidden rounded-3xl border bg-[var(--color-surface)] transition-all hover:-translate-y-1 hover:shadow-2xl flex flex-col',
            cat.primary
              ? 'col-span-2 md:col-span-2 md:row-span-2 border-[var(--color-primary)]/50 hover:border-[var(--color-primary)] hover:shadow-[var(--color-primary)]/30 aspect-square md:aspect-auto md:min-h-[400px]'
              : 'border-[var(--color-border)]/60 hover:border-[var(--color-primary)]/60 hover:shadow-[var(--color-primary)]/10 aspect-[4/5]',
          ].join(' ')}
        >
          {/* Görsel/Gradient */}
          <div class="relative flex-1 overflow-hidden bg-gradient-to-br from-[var(--color-surface-2)] to-[var(--color-surface)]">
            {cat.image ? (
              <img
                src={cat.image}
                alt={cat.name}
                loading={i === 0 ? 'eager' : 'lazy'}
                decoding="async"
                class="size-full object-cover group-hover:scale-105 transition-transform duration-700"
              />
            ) : (
              <div class="absolute inset-0 grid place-items-center">
                <span class={cat.primary ? 'text-[180px] opacity-80' : 'text-[88px] opacity-80'}>{cat.emoji}</span>
              </div>
            )}
            {cat.count !== undefined && (
              <span class="absolute top-3 right-3 px-2.5 py-1 rounded-full bg-black/60 backdrop-blur-md text-white text-[10px] font-bold uppercase tracking-wider">
                {cat.count} ürün
              </span>
            )}
            {cat.primary && (
              <span class="absolute top-3 right-3 px-3 py-1.5 rounded-full bg-[var(--color-primary)] text-black text-[11px] font-black uppercase tracking-wider">
                ⭐ Ana Ürün
              </span>
            )}
          </div>

          {/* Bilgi */}
          <div class={cat.primary ? 'p-6 md:p-8' : 'p-4 md:p-5'}>
            <h3 class={cat.primary ? 'font-display text-2xl md:text-3xl font-bold tracking-tight' : 'font-display text-base md:text-lg font-semibold'}>
              {cat.name}
            </h3>
            <p class={[
              'mt-1.5 text-[var(--color-text-muted)] leading-relaxed line-clamp-2',
              cat.primary ? 'text-sm md:text-base' : 'text-xs md:text-sm',
            ].join(' ')}>
              {cat.description}
            </p>
            <div class={[
              'mt-3 inline-flex items-center gap-1.5 font-bold text-[var(--color-primary)] group-hover:gap-2.5 transition-all',
              cat.primary ? 'text-base' : 'text-sm',
            ].join(' ')}>
              {cat.cta}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
