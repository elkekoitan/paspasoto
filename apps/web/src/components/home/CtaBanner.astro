---
---

<section class="container-page py-12 md:py-20">
  <div
    class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-[var(--color-surface-2)] via-[var(--color-surface)] to-[var(--color-surface-2)] border border-[var(--color-border)]/60 p-10 md:p-16"
  >
    <div
      class="absolute -top-20 -right-20 size-72 rounded-full bg-[var(--color-primary)]/15 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute -bottom-20 -left-20 size-72 rounded-full bg-[var(--color-info)]/10 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="relative max-w-2xl">
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-semibold tracking-tight leading-tight">
        Aracını seç, paspasını birlikte tasarlayalım.
      </h2>
      <p class="mt-4 text-lg text-[var(--color-text-soft)]">
        7 adımlık konfigüratör · Canlı önizleme · Şeffaf üretim takibi.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href="/konfigurator"
          class="inline-flex items-center gap-2 px-6 py-3.5 rounded-xl text-base font-semibold bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-[var(--color-bg)] transition-all hover:shadow-[var(--shadow-glow)]"
        >
          Hemen Başla
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
        <a
          href="https://wa.me/905550000000"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-5 py-3.5 rounded-xl text-base font-medium border border-[var(--color-border)] hover:border-[var(--color-text-muted)] hover:bg-[var(--color-surface-2)]/60 transition-colors"
        >
          WhatsApp'tan Yaz
        </a>
      </div>
    </div>
  </div>
</section>
