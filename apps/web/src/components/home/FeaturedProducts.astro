---
/**
 * FeaturedProducts — Ana sayfa için 3 yatay carousel:
 *  - Çok Satan (best-seller)
 *  - İndirimde (discount)
 *  - Diğer Ürünlerimiz (kalan tüm aktif ürünler, karışık)
 *
 * Hepsi dairesel showcase + snap horizontal scroll kullanır.
 */
import ProductCarousel from './ProductCarousel.astro'
import { ALL_SIMPLE_PRODUCTS } from '@lib/catalog-extra'

const bestSellers = ALL_SIMPLE_PRODUCTS.filter((p) => p.badges?.includes('best-seller') && p.active).slice(0, 10)
const discounted = ALL_SIMPLE_PRODUCTS.filter((p) => p.badges?.includes('discount') && p.active).slice(0, 10)

// Diğer ürünler: best-seller veya discount değil OLAN aktif ürünler
const otherProducts = ALL_SIMPLE_PRODUCTS.filter(
  (p) => p.active && !p.badges?.includes('best-seller') && !p.badges?.includes('discount'),
).slice(0, 12)
---

<div class="bg-[var(--color-bg)]">
  {bestSellers.length > 0 && (
    <ProductCarousel
      title="Müşterilerimizin Tercihi"
      subtitle="Atölyemizden en çok sevilen ve önerilen ürünler."
      eyebrow="⭐ ÇOK SATAN"
      products={bestSellers}
      accent="amber"
      href="/urunler"
      hrefLabel="Tümünü gör"
    />
  )}

  {discounted.length > 0 && (
    <ProductCarousel
      title="Bu Hafta İndirimde"
      subtitle="Sınırlı süreyle özel fiyatlarla — sepete eklemeden kaçırma."
      eyebrow="🏷️ FIRSAT"
      products={discounted}
      accent="rose"
      href="/urunler"
      hrefLabel="Tümünü gör"
    />
  )}

  {otherProducts.length > 0 && (
    <ProductCarousel
      title="Diğer Ürünlerimiz"
      subtitle="Aracın için seçilmiş premium aksesuarlar."
      eyebrow="🛍 KATALOG"
      products={otherProducts}
      accent="primary"
      href="/urunler"
      hrefLabel="Tüm kataloğu gör"
    />
  )}
</div>
