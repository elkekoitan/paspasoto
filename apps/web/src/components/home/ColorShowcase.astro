---
import { MAT_COLORS, BORDER_COLORS, HEEL_PADS } from '@lib/catalog'
---

<section
  class="relative overflow-hidden py-24 md:py-32 bg-[var(--color-surface)]/30 border-y border-[var(--color-border)]/40"
  data-reveal
>
  {/* Arkaplan efekti */}
  <div
    class="absolute inset-0 -z-10 opacity-50"
    style="background:
      radial-gradient(ellipse 50% 40% at 25% 30%, rgba(212,146,58,0.08), transparent 60%),
      radial-gradient(ellipse 50% 40% at 75% 70%, rgba(59,130,246,0.06), transparent 60%);"
    aria-hidden="true"
  >
  </div>

  <div class="container-page">
    <div class="text-center max-w-3xl mx-auto mb-16 md:mb-20">
      <p class="text-sm text-[var(--color-primary)] font-medium uppercase tracking-[0.2em]">
        Sınırsız kombinasyon
      </p>
      <h2 class="mt-3 font-display text-4xl md:text-6xl font-semibold tracking-tight leading-[1.05]">
        <span class="tabular-nums">10</span> paspas <span class="text-[var(--color-text-muted)]">·</span>
        <span class="tabular-nums">15</span> kenarlık <span class="text-[var(--color-text-muted)]">·</span>
        <span class="tabular-nums">8</span> topukluk
      </h2>
      <p class="mt-5 text-lg text-[var(--color-text-soft)]">
        Her kombinasyon, atölyemizden çıkmadan önce gözden geçirilir.
      </p>
    </div>

    {/* Paspas zemin renkleri */}
    <div class="mb-16">
      <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
        <h3 class="font-display text-xl font-semibold flex items-center gap-3">
          <span class="size-1.5 rounded-full bg-[var(--color-primary)]"></span>
          Paspas Zemin Rengi
        </h3>
        <span class="text-xs text-[var(--color-text-muted)] font-medium">10 seçenek</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-5 gap-3 md:gap-4">
        {
          MAT_COLORS.map((c) => (
            <button
              type="button"
              class="group relative flex flex-col gap-2 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/40 p-2.5 hover:border-[var(--color-primary)]/40 hover:bg-[var(--color-surface-2)] transition-all hover:-translate-y-1"
              aria-label={c.name}
            >
              <div class="aspect-[4/3] rounded-xl overflow-hidden ring-1 ring-[var(--color-border)] group-hover:ring-[var(--color-primary)]/40 transition-all">
                <img
                  src={c.swatchUrl}
                  alt={`${c.name} dokulu paspas`}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                />
              </div>
              <div class="flex items-center justify-between px-1">
                <span class="text-xs font-medium text-[var(--color-text)]">{c.name}</span>
                <span
                  class="size-3 rounded-full ring-1 ring-[var(--color-border)]"
                  style={`background: ${c.hex};`}
                  aria-hidden="true"
                />
              </div>
            </button>
          ))
        }
      </div>
    </div>

    {/* Kenarlık renkleri */}
    <div class="mb-16">
      <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
        <h3 class="font-display text-xl font-semibold flex items-center gap-3">
          <span class="size-1.5 rounded-full bg-[var(--color-primary)]"></span>
          Kenarlık Rengi
        </h3>
        <span class="text-xs text-[var(--color-text-muted)] font-medium">15 seçenek</span>
      </div>
      <div class="grid grid-cols-3 sm:grid-cols-5 lg:grid-cols-5 gap-2.5 md:gap-3">
        {
          BORDER_COLORS.map((c) => (
            <button
              type="button"
              class="group relative flex flex-col gap-1.5 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)]/40 p-2 hover:border-[var(--color-primary)]/40 transition-all hover:-translate-y-0.5"
              aria-label={c.name}
            >
              <div class="aspect-[5/3] rounded-lg overflow-hidden ring-1 ring-[var(--color-border)] group-hover:ring-[var(--color-primary)]/40 transition-all">
                <img
                  src={c.swatchUrl}
                  alt={`${c.name} kenarlık dokusu`}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                />
              </div>
              <span class="text-[11px] font-medium text-[var(--color-text-soft)] group-hover:text-[var(--color-text)] truncate text-center transition-colors">
                {c.name}
              </span>
            </button>
          ))
        }
      </div>
    </div>

    {/* Topukluk */}
    <div>
      <div class="flex items-baseline justify-between mb-6 flex-wrap gap-2">
        <h3 class="font-display text-xl font-semibold flex items-center gap-3">
          <span class="size-1.5 rounded-full bg-[var(--color-primary)]"></span>
          Topukluk Doku
          <span class="text-xs text-[var(--color-text-muted)] font-normal ml-2">aşınmayı önler</span>
        </h3>
        <span class="text-xs text-[var(--color-text-muted)] font-medium">8 seçenek</span>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 md:gap-4">
        {
          HEEL_PADS.map((h) => (
            <button
              type="button"
              class="group relative flex flex-col gap-2 rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/40 p-2.5 hover:border-[var(--color-primary)]/40 transition-all hover:-translate-y-1"
              aria-label={h.name}
            >
              <div class="aspect-[5/3] rounded-xl overflow-hidden ring-1 ring-[var(--color-border)] group-hover:ring-[var(--color-primary)]/40 transition-all relative">
                <img
                  src={h.swatchUrl}
                  alt={`${h.name} topukluk dokusu`}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                />
                {h.isStandard && (
                  <span class="absolute top-2 right-2 px-2 py-0.5 text-[9px] rounded-full bg-[var(--color-success)]/90 text-white font-semibold uppercase tracking-wider">
                    Standart
                  </span>
                )}
                {!h.isStandard && h.pricePremium > 0 && (
                  <span class="absolute top-2 right-2 px-2 py-0.5 text-[9px] rounded-full bg-[var(--color-bg)]/80 backdrop-blur text-[var(--color-primary)] font-semibold">
                    +{h.pricePremium} ₺
                  </span>
                )}
              </div>
              <span class="text-xs font-medium text-[var(--color-text-soft)] group-hover:text-[var(--color-text)] text-center transition-colors px-1">
                {h.name}
              </span>
            </button>
          ))
        }
      </div>
    </div>

    <div class="mt-16 text-center">
      <a
        href="/konfigurator"
        class="group inline-flex items-center gap-2 px-6 py-3.5 rounded-2xl text-sm font-semibold border-2 border-[var(--color-primary)]/40 text-[var(--color-primary)] hover:bg-[var(--color-primary)] hover:text-[var(--color-bg)] hover:border-[var(--color-primary)] transition-colors"
      >
        Kombinasyon yapmaya başla
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-1 transition-transform">
          <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
