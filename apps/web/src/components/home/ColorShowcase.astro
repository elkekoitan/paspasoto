---
import { MAT_COLORS, BORDER_COLORS, HEEL_PADS } from '@lib/catalog'
---

<section class="relative overflow-hidden py-20 md:py-28 bg-[var(--color-surface)]/40 border-y border-[var(--color-border)]/50">
  <div class="absolute inset-0 -z-10 gradient-radial opacity-50" aria-hidden="true"></div>

  <div class="container-page">
    <div class="text-center max-w-2xl mx-auto mb-14">
      <p class="text-sm text-[var(--color-primary)] font-medium uppercase tracking-wider">
        Sınırsız kombinasyon
      </p>
      <h2 class="mt-2 font-display text-3xl md:text-4xl font-semibold tracking-tight">
        10 paspas · 18 kenarlık · 8 topukluk
      </h2>
      <p class="mt-3 text-[var(--color-text-soft)]">
        Aracının ruhunu yansıtan kombinasyonu seç. Konfigüratörde canlı önizleme ile.
      </p>
    </div>

    <!-- Paspas zemin renkleri -->
    <div class="mb-10">
      <h3 class="text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-4 font-semibold">
        Paspas Zemin Rengi · 10 seçenek
      </h3>
      <div class="grid grid-cols-5 sm:grid-cols-10 gap-2.5">
        {
          MAT_COLORS.map((c) => (
            <div class="group">
              <div
                class="aspect-square rounded-lg ring-1 ring-[var(--color-border)] hover:ring-[var(--color-primary)] transition-all hover:scale-[1.04] cursor-pointer relative overflow-hidden"
                style={`background: ${c.hex};`}
                title={c.name}
              >
                <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_30%,rgba(255,255,255,0.08),transparent_60%)]" />
              </div>
              <div class="mt-1.5 text-[10px] sm:text-xs text-center text-[var(--color-text-muted)] group-hover:text-[var(--color-text)] truncate">
                {c.name}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Kenarlık renkleri -->
    <div class="mb-10">
      <h3 class="text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-4 font-semibold">
        Kenarlık Rengi · 18 seçenek
      </h3>
      <div class="grid grid-cols-6 sm:grid-cols-9 lg:grid-cols-18 gap-2">
        {
          BORDER_COLORS.map((c) => (
            <div class="group">
              <div
                class="aspect-square rounded-md ring-1 ring-[var(--color-border)] hover:ring-[var(--color-primary)] transition-all hover:scale-105 cursor-pointer relative overflow-hidden"
                style={`background: ${c.hex};`}
                title={c.name}
              />
              <div class="mt-1 text-[10px] text-center text-[var(--color-text-muted)] truncate">
                {c.name}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Topukluk -->
    <div>
      <h3 class="text-xs uppercase tracking-wider text-[var(--color-text-muted)] mb-4 font-semibold">
        Topukluk Doku · 8 seçenek
      </h3>
      <div class="grid grid-cols-4 sm:grid-cols-8 gap-2.5">
        {
          HEEL_PADS.map((h) => (
            <div class="group">
              <div
                class="aspect-[4/3] rounded-lg ring-1 ring-[var(--color-border)] hover:ring-[var(--color-primary)] transition-all hover:scale-[1.04] cursor-pointer relative overflow-hidden"
                style={`background: ${h.textureHex};`}
                title={h.name}
              >
                {/* Doku simülasyonu — gerçek görsel Strapi'den swatch ile değişecek */}
                <div
                  class="absolute inset-0 opacity-50"
                  style="background-image: radial-gradient(circle at 25% 25%, rgba(255,255,255,0.18) 1px, transparent 2px), radial-gradient(circle at 75% 75%, rgba(255,255,255,0.12) 1px, transparent 2px); background-size: 8px 8px, 12px 12px;"
                />
                {h.isStandard && (
                  <span class="absolute top-1 right-1 px-1.5 py-0.5 text-[9px] rounded-full bg-[var(--color-success)]/20 text-[var(--color-success)] font-medium">
                    Standart
                  </span>
                )}
              </div>
              <div class="mt-1.5 text-[10px] sm:text-xs text-center text-[var(--color-text-muted)] group-hover:text-[var(--color-text)] truncate">
                {h.name}
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-12 text-center">
      <a
        href="/konfigurator"
        class="inline-flex items-center gap-2 px-5 py-3 rounded-lg text-sm font-semibold border border-[var(--color-primary)] text-[var(--color-primary)] hover:bg-[var(--color-primary)] hover:text-[var(--color-bg)] transition-colors"
      >
        Kombinasyon yapmaya başla
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
