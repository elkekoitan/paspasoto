---
/**
 * HeroV2 — 35-40+ hedef e-ticaret odaklı ana sayfa hero'su.
 *
 * Tasarım kararları:
 * - Büyük başlık (mobil 32px, desktop 48-56px)
 * - Tek net CTA + WhatsApp ikinci CTA
 * - Sağ tarafta paspas görseli
 * - Altında 4 ürün kategori thumbnail (parfüm, çanta, kimya, ekran koruyucu)
 * - Tap target ≥56px
 * - High contrast, sade
 */
import { CATEGORY_META } from '@lib/catalog-extra'

const heroImage = '/assets/mats/hero/default.webp'

const productThumbs = [
  CATEGORY_META.perfume,
  CATEGORY_META.chemical,
  CATEGORY_META.bag,
  CATEGORY_META['screen-protector'],
]
---

<section class="relative overflow-hidden bg-[var(--color-bg)] border-b border-[var(--color-border)]/40">
  {/* Atmosfer arkaplan */}
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 80% 60% at 30% 20%, rgba(212,146,58,0.12), transparent 60%), radial-gradient(ellipse 60% 50% at 80% 80%, rgba(212,146,58,0.06), transparent 70%);"
    aria-hidden
  ></div>

  <div class="container-page relative pt-8 pb-12 md:pt-16 md:pb-20">
    <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-center">
      {/* Sol kolon: başlık + CTA */}
      <div class="order-2 md:order-1">
        <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-[var(--color-primary-soft)] ring-1 ring-[var(--color-primary)]/30 text-[11px] uppercase tracking-[0.2em] text-[var(--color-primary)] font-bold mb-5">
          <span class="size-1.5 rounded-full bg-[var(--color-primary)] animate-pulse"></span>
          3 günde üretim · Atölyeden kapına
        </span>

        <h1 class="font-display font-bold tracking-tight leading-[1.05] text-[34px] md:text-[56px] lg:text-[64px]">
          Aracına özel <span class="text-[var(--color-primary)]">EVA paspas</span>.<br />
          Premium kalite, atölye fiyatı.
        </h1>

        <p class="mt-5 text-base md:text-lg text-[var(--color-text-soft)] leading-relaxed max-w-xl">
          Lazer ölçü ile birebir uyumlu. <strong class="text-white">3000+ araç modeli</strong>, 10 paspas rengi, 15 kenarlık seçeneği. 2 yıl garanti.
        </p>

        {/* CTA'lar — büyük tap target */}
        <div class="mt-7 flex flex-col sm:flex-row gap-3">
          <a
            href="/konfigurator"
            class="group inline-flex items-center justify-center gap-2.5 px-7 py-4 min-h-[60px] rounded-xl bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-[var(--color-bg)] font-bold text-base md:text-lg transition-all hover:shadow-[var(--shadow-glow)] hover:scale-[1.02]"
          >
            PASPASINI TASARLA
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform group-hover:translate-x-1">
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
          </a>
          <a
            href="https://wa.me/905447108115?text=Merhaba%2C+aracıma+özel+paspas+hakkında+bir+sorum+var."
            target="_blank"
            rel="noopener"
            class="inline-flex items-center justify-center gap-2.5 px-6 py-4 min-h-[60px] rounded-xl bg-emerald-500/15 hover:bg-emerald-500/25 text-emerald-400 border-2 border-emerald-500/40 font-bold text-base transition-all"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.296-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/></svg>
            WhatsApp'tan Sor
          </a>
        </div>

        {/* Trust badges altı */}
        <div class="mt-7 flex items-center gap-5 text-xs text-[var(--color-text-muted)]">
          <span class="flex items-center gap-1.5"><span class="text-emerald-400">✓</span> 2 yıl garanti</span>
          <span class="flex items-center gap-1.5"><span class="text-emerald-400">✓</span> Kargo dahil</span>
          <span class="flex items-center gap-1.5"><span class="text-emerald-400">✓</span> 14 gün iade</span>
        </div>
      </div>

      {/* Sağ kolon: paspas görseli */}
      <div class="order-1 md:order-2 relative">
        <div class="aspect-[4/3] md:aspect-square relative overflow-hidden rounded-3xl bg-gradient-to-br from-[#1a1a22] to-[#0b0b0f] border border-white/10 shadow-2xl">
          <img
            src={heroImage}
            alt="Aracına özel EVA paspas — premium kalite"
            class="absolute inset-0 size-full object-cover"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
          {/* Sağ üst rozet */}
          <div class="absolute top-4 right-4 px-3 py-1.5 rounded-full bg-black/70 backdrop-blur-md text-[11px] font-bold text-white border border-white/20">
            ⭐ 4.9/5 müşteri puanı
          </div>
        </div>
      </div>
    </div>

    {/* 4 ürün kategori thumbnail mini-grid */}
    <div class="mt-10 md:mt-14">
      <div class="flex items-center justify-between gap-3 mb-4">
        <h2 class="text-[10px] md:text-xs uppercase tracking-[0.2em] text-[var(--color-text-muted)] font-bold">
          Diğer ürünlerimiz
        </h2>
        <a href="/urunler" class="text-xs text-[var(--color-primary)] hover:underline font-semibold">
          Tümünü gör →
        </a>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 md:gap-4">
        {productThumbs.map((cat) => (
          <a
            href={cat.href}
            class="group flex items-center gap-3 p-4 min-h-[80px] rounded-2xl bg-[var(--color-surface)] border border-[var(--color-border)]/60 hover:border-[var(--color-primary)]/60 hover:-translate-y-0.5 transition-all"
          >
            <span class="text-3xl shrink-0">{cat.emoji}</span>
            <div class="min-w-0">
              <div class="font-semibold text-sm md:text-base text-white line-clamp-1">{cat.name}</div>
              <div class="text-[11px] text-[var(--color-text-muted)] mt-0.5 group-hover:text-[var(--color-primary)] transition-colors">Keşfet →</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
