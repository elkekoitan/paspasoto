---
const USP = [
  {
    title: '%100 Araca Özel',
    desc: 'Lazer ölçülü kalıp, milimetrik hassasiyet.',
    icon: 'M12 2 2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5',
  },
  {
    title: 'Premium Malzeme',
    desc: 'Kokusuz, kıvrılmaz EVA + termoplastik karışımı.',
    icon: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z',
  },
  {
    title: '7 Gün İçinde Üretim',
    desc: 'Sipariş onayından kargoya: ortalama 5-7 iş günü.',
    icon: 'M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0z',
  },
  {
    title: 'Şeffaf Sipariş Takibi',
    desc: 'Üretim aşamasını canlı görsel timeline ile izle.',
    icon: 'M22 11.08V12a10 10 0 1 1-5.93-9.14M22 4 12 14.01l-3-3',
  },
]
---

<section class="border-y border-[var(--color-border)]/50 bg-[var(--color-surface)]/40" data-reveal>
  <div class="container-page py-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
      {
        USP.map((item) => (
          <div class="flex items-start gap-3.5">
            <span
              class="grid size-10 shrink-0 place-items-center rounded-lg bg-[var(--color-primary-soft)] text-[var(--color-primary)] ring-1 ring-[var(--color-primary)]/20"
              aria-hidden="true"
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={item.icon} />
              </svg>
            </span>
            <div>
              <h3 class="text-sm font-semibold text-[var(--color-text)]">{item.title}</h3>
              <p class="mt-1 text-xs text-[var(--color-text-muted)] leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
