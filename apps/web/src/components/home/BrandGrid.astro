---
import { POPULAR_BRANDS, VEHICLE_MODELS, BRANDS } from '@lib/catalog'

// Her marka için aktif model sayısı (Türkiye pazarı tamamlandı 150 model)
function modelCountFor(slug: string): number {
  return VEHICLE_MODELS.filter((m) => m.brandSlug === slug).length
}

const totalModels = VEHICLE_MODELS.length
const totalBrands = BRANDS.length
---

<section class="container-page py-24 md:py-32" data-reveal>
  <div class="flex items-end justify-between flex-wrap gap-4 mb-12 md:mb-16">
    <div>
      <p class="text-sm text-[var(--color-primary)] font-medium uppercase tracking-[0.2em]">
        Marka Uyumu
      </p>
      <h2 class="mt-3 font-display text-3xl md:text-5xl font-semibold tracking-tight max-w-2xl leading-[1.1]">
        Audi'den Dacia'ya, BMW'den Toyota'ya — <span class="text-[var(--color-text-muted)]">{totalModels}+ model, {totalBrands} marka.</span>
      </h2>
    </div>
    <a
      href="/markalar"
      class="text-sm font-medium text-[var(--color-text-soft)] hover:text-[var(--color-primary)] transition-colors flex items-center gap-1.5 group"
    >
      Tümünü gör
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform">
        <path d="m9 18 6-6-6-6"></path>
      </svg>
    </a>
  </div>

  <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-7 gap-2 md:gap-3">
    {
      POPULAR_BRANDS.map((brand) => {
        const brandColor = brand.color || '#444'
        const logoUrl = brand.logoUrl || `/assets/brands/${brand.slug}.svg`
        const modelCount = modelCountFor(brand.slug)
        return (
          <a
            href={`/konfigurator?brand=${brand.slug}`}
            class="group relative aspect-square rounded-2xl border-2 border-white/10 hover:border-[var(--color-primary)]/60 overflow-hidden transition-all hover:-translate-y-1 hover:scale-[1.03] hover:shadow-2xl"
            aria-label={`${brand.name} — ${modelCount} model`}
          >
            {/* Brand color radial gradient bg — her marka kendi rengini yansıtır */}
            <div
              class="absolute inset-0 opacity-15 group-hover:opacity-35 transition-opacity"
              style={`background: radial-gradient(circle at 50% 30%, ${brandColor}, transparent 70%);`}
            />
            {/* Glassmorphic overlay */}
            <div class="absolute inset-0 bg-gradient-to-br from-white/8 via-transparent to-black/20 pointer-events-none" />
            {/* Model count badge — sol üst (sadece >= 2 model varsa) */}
            {modelCount >= 2 && (
              <span class="absolute top-2 left-2 px-1.5 py-0.5 rounded-md bg-black/60 backdrop-blur-md text-[8px] md:text-[9px] font-bold text-white/90 z-20 tabular-nums tracking-wider">
                {modelCount} MODEL
              </span>
            )}
            {/* İçerik — büyük beyaz logo + marka adı */}
            <div class="relative h-full flex flex-col items-center justify-center gap-2 p-2 z-10">
              <img
                src={logoUrl}
                alt={brand.name}
                class="size-10 md:size-12 object-contain transition-transform group-hover:scale-110"
                style="filter: brightness(0) invert(1) drop-shadow(0 2px 8px rgba(0,0,0,0.3));"
                loading="lazy"
              />
              <span class="text-[10px] md:text-xs font-semibold text-white/80 group-hover:text-white tracking-wide uppercase transition-colors">
                {brand.name}
              </span>
            </div>
            {/* Hover indicator dot */}
            <span class="absolute top-2 right-2 size-2 rounded-full bg-[var(--color-primary)] opacity-0 group-hover:opacity-100 transition-opacity shadow-[0_0_10px_var(--color-primary)]" />
          </a>
        )
      })
    }
  </div>
</section>
