---
import { POPULAR_BRANDS } from '@lib/catalog'
import BrandLogo from '@components/ui/BrandLogo.astro'
---

<section class="container-page py-24 md:py-32" data-reveal>
  <div class="flex items-end justify-between flex-wrap gap-4 mb-12 md:mb-16">
    <div>
      <p class="text-sm text-[var(--color-primary)] font-medium uppercase tracking-[0.2em]">
        Marka Uyumu
      </p>
      <h2 class="mt-3 font-display text-3xl md:text-5xl font-semibold tracking-tight max-w-2xl leading-[1.1]">
        Audi'den Dacia'ya, BMW'den Toyota'ya — <span class="text-[var(--color-text-muted)]">3000+ model.</span>
      </h2>
    </div>
    <a
      href="/markalar"
      class="text-sm font-medium text-[var(--color-text-soft)] hover:text-[var(--color-primary)] transition-colors flex items-center gap-1.5 group"
    >
      Tümünü gör
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform">
        <path d="m9 18 6-6-6-6"></path>
      </svg>
    </a>
  </div>

  <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-6 lg:grid-cols-7 gap-3 md:gap-4">
    {
      POPULAR_BRANDS.map((brand) => (
        <a
          href={`/konfigurator?brand=${brand.slug}`}
          class="group relative aspect-square flex flex-col items-center justify-center gap-2 rounded-2xl border border-[var(--color-border)]/60 bg-[var(--color-surface)]/50 backdrop-blur hover:bg-[var(--color-surface-2)] hover:border-[var(--color-primary)]/40 transition-all hover:-translate-y-1 hover:shadow-2xl hover:shadow-[var(--color-primary)]/5"
        >
          <BrandLogo
            iconSlug={brand.iconSlug}
            name={brand.name}
            size={36}
            class="text-[var(--color-text-soft)] group-hover:text-[var(--color-primary)] transition-colors"
          />
          <span class="text-[10px] font-medium text-[var(--color-text-muted)] group-hover:text-[var(--color-text)] tracking-wide uppercase transition-colors">
            {brand.name}
          </span>
          <span class="absolute top-2 right-2 size-1.5 rounded-full bg-[var(--color-primary)] opacity-0 group-hover:opacity-100 transition-opacity" />
        </a>
      ))
    }
  </div>
</section>
