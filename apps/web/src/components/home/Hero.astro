---
// Sinematik Hero — Apple/Tesla seviyesi premium otomotiv hissi.
// Tam ekran, paralaks scroll, dramatik ışık, video-benzeri statik görsel.
---

<section class="relative overflow-hidden min-h-[100svh] flex items-center" data-hero>
  {/* Arka katman: koyu gradient + sahne */}
  <div class="absolute inset-0 -z-30 bg-[var(--color-bg)]"></div>

  {/* Spotlight ışıkları */}
  <div
    class="absolute inset-0 -z-20"
    style="background:
      radial-gradient(ellipse 60% 40% at 75% 30%, rgba(212,146,58,0.18), transparent 60%),
      radial-gradient(ellipse 50% 50% at 20% 80%, rgba(59,130,246,0.10), transparent 60%);"
    aria-hidden="true"
  >
  </div>

  {/* Hero görseli — sağ %50, daha az saldırgan mask (sol boşluk dengelenir) */}
  <picture class="absolute inset-y-0 right-0 w-full md:w-[52%] -z-10 pointer-events-none" aria-hidden="true">
    <source srcset="/assets/mats/hero-stack.avif" type="image/avif" />
    <source srcset="/assets/mats/hero-stack.webp" type="image/webp" />
    <img
      src="/assets/mats/hero-stack.webp"
      alt=""
      loading="eager"
      fetchpriority="high"
      decoding="async"
      class="size-full object-cover object-center scale-105 opacity-55 md:opacity-95"
      style="mask-image: linear-gradient(to right, transparent 0%, black 20%, black 100%);
             -webkit-mask-image: linear-gradient(to right, transparent 0%, black 20%, black 100%);
             transform: translateY(var(--hero-parallax, 0px)) scale(1.08);"
      data-parallax
    />
  </picture>

  {/* Soldan sağa fade — daha yumuşak, sol-orta alanda renk geçişi */}
  <div
    class="absolute inset-0 -z-10"
    style="background: linear-gradient(to right,
      var(--color-bg) 0%,
      var(--color-bg) 15%,
      rgba(11,11,15,0.85) 40%,
      rgba(11,11,15,0.4) 65%,
      transparent 100%);"
    aria-hidden="true"
  >
  </div>

  {/* Sol-alt cinematic accent — Konya atölye işareti, sol boşluğu doldurur */}
  <div
    class="absolute bottom-0 left-0 w-full md:w-[48%] h-[45%] -z-10"
    style="background: linear-gradient(135deg, var(--color-bg) 0%, rgba(11,11,15,0.85) 50%, transparent 100%);"
    aria-hidden="true"
  >
  </div>

  {/* Sol dekoratif geometric accent — premium otomotiv hissi (Tesla/BMW pattern) */}
  <svg
    class="absolute left-0 top-1/2 -translate-y-1/2 -z-10 hidden lg:block opacity-[0.04] pointer-events-none"
    width="380"
    height="380"
    viewBox="0 0 380 380"
    aria-hidden="true"
  >
    <defs>
      <linearGradient id="hero-accent" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" stop-color="var(--color-primary)" />
        <stop offset="100%" stop-color="transparent" />
      </linearGradient>
    </defs>
    {/* Konsantrik daireler — atölye/precision sembolü */}
    <circle cx="190" cy="190" r="180" fill="none" stroke="url(#hero-accent)" stroke-width="1" />
    <circle cx="190" cy="190" r="140" fill="none" stroke="url(#hero-accent)" stroke-width="1" />
    <circle cx="190" cy="190" r="100" fill="none" stroke="url(#hero-accent)" stroke-width="1" />
    <circle cx="190" cy="190" r="60" fill="none" stroke="url(#hero-accent)" stroke-width="1" />
    {/* Kesişim çizgileri */}
    <line x1="0" y1="190" x2="380" y2="190" stroke="url(#hero-accent)" stroke-width="0.5" />
    <line x1="190" y1="0" x2="190" y2="380" stroke="url(#hero-accent)" stroke-width="0.5" />
  </svg>

  {/* Üst & alt vignette */}
  <div
    class="absolute inset-0 -z-10 bg-gradient-to-b from-[var(--color-bg)] via-transparent to-[var(--color-bg)]/95"
    aria-hidden="true"
  >
  </div>

  {/* İçerik */}
  <div class="container-page relative z-10 py-24 md:py-32">
    <div class="max-w-3xl">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-[var(--color-border)] bg-[var(--color-surface)]/60 backdrop-blur-md px-3.5 py-1.5 text-xs font-medium text-[var(--color-text-soft)] hero-fade-in"
        style="animation-delay: 0.1s;"
      >
        <span class="size-1.5 rounded-full bg-[var(--color-primary)] animate-pulse"></span>
        Konya'dan kapına · 3000+ araç modeli uyumu
      </span>

      <h1
        class="mt-6 font-display text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-semibold leading-[0.98] tracking-tight hero-fade-in"
        style="animation-delay: 0.2s;"
      >
        Aracına özel,
        <br />
        <span class="text-gradient-amber">atölyemizden</span>
        <br />
        <span class="text-[var(--color-text)]">kapına.</span>
      </h1>

      <p
        class="mt-8 text-lg md:text-xl text-[var(--color-text-soft)] max-w-2xl leading-relaxed hero-fade-in"
        style="animation-delay: 0.35s;"
      >
        Lazer ölçülü kalıplar, 10 paspas + 15 kenarlık rengi, premium topukluk ve marka ambleminle
        senin için özel kişiselleştirilen 3D havuzlu paspaslar.
      </p>

      <div
        class="mt-10 flex flex-wrap items-center gap-3 hero-fade-in"
        style="animation-delay: 0.5s;"
      >
        <a
          href="/konfigurator"
          class="group relative inline-flex items-center gap-2 px-7 py-4 rounded-2xl text-base font-semibold bg-[var(--color-primary)] hover:bg-[var(--color-primary-hover)] text-[var(--color-bg)] transition-all hover:shadow-[var(--shadow-glow)] hover:-translate-y-0.5"
        >
          <span class="absolute inset-0 rounded-2xl bg-gradient-to-r from-transparent via-white/20 to-transparent translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700"></span>
          <span class="relative">Paspasınızı Tasarlayın</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
            class="relative group-hover:translate-x-1 transition-transform"
          >
            <path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path>
          </svg>
        </a>
        <a
          href="/galeri"
          class="inline-flex items-center gap-2 px-6 py-4 rounded-2xl text-base font-medium border border-[var(--color-border)] hover:border-[var(--color-text-muted)] hover:bg-[var(--color-surface)]/60 backdrop-blur transition-all"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect><circle cx="9" cy="9" r="2"></circle><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
          </svg>
          Müşteri Kombinleri
        </a>
      </div>

      {/* Sosyal kanıt mini şerit */}
      <div
        class="mt-16 grid grid-cols-2 sm:grid-cols-4 gap-x-8 gap-y-6 hero-fade-in"
        style="animation-delay: 0.7s;"
      >
        {[
          { num: '3000+', label: 'Araç modeli' },
          { num: '3 gün', label: 'Üretim süresi' },
          { num: '2 yıl', label: 'Garanti' },
          { num: '%100', label: 'Araca özel kalıp' },
        ].map((s) => (
          <div>
            <div class="font-display text-3xl md:text-4xl font-semibold text-[var(--color-text)] tabular-nums">
              {s.num}
            </div>
            <div class="mt-1 text-xs text-[var(--color-text-muted)] uppercase tracking-wider">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  {/* Scroll cue */}
  <div
    class="absolute bottom-6 left-1/2 -translate-x-1/2 hidden md:flex flex-col items-center gap-2 text-[var(--color-text-muted)]/60"
    aria-hidden="true"
  >
    <span class="text-[10px] uppercase tracking-[0.3em]">Keşfet</span>
    <span class="size-9 grid place-items-center rounded-full border border-[var(--color-border)]">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce">
        <path d="M12 5v14M19 12l-7 7-7-7"></path>
      </svg>
    </span>
  </div>
</section>

<style>
  @keyframes heroFade {
    0% { opacity: 0; transform: translateY(16px); filter: blur(6px); }
    100% { opacity: 1; transform: translateY(0); filter: blur(0); }
  }
  .hero-fade-in {
    animation: heroFade 800ms cubic-bezier(0.21, 1, 0.21, 1) both;
  }
</style>

<script>
  // Parallax effect — paspas görselini kaydır
  const img = document.querySelector('[data-parallax]') as HTMLElement | null
  if (img && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    let raf = 0
    const onScroll = () => {
      cancelAnimationFrame(raf)
      raf = requestAnimationFrame(() => {
        const y = Math.min(window.scrollY * 0.25, 200)
        img.style.setProperty('--hero-parallax', `${y}px`)
      })
    }
    window.addEventListener('scroll', onScroll, { passive: true })
  }
</script>
