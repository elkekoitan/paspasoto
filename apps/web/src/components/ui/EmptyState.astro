---
/**
 * EmptyState — "Henüz X yok" mesajları için.
 *
 * Kullanım:
 *   <EmptyState
 *     emoji="📦"
 *     title="Henüz sipariş yok"
 *     description="Yeni sipariş geldikçe burada listelenir."
 *   />
 *
 * Slot ile CTA eklenebilir:
 *   <EmptyState title="...">
 *     <Button slot="cta" href="/admin/orders/new">+ Yeni Sipariş</Button>
 *   </EmptyState>
 */

interface Props {
  emoji?: string
  title: string
  description?: string
  class?: string
  size?: 'sm' | 'md' | 'lg'
}

const { emoji, title, description, class: classes = '', size = 'md' } = Astro.props

const sizes = {
  sm: { container: 'py-8', emoji: 'text-4xl', title: 'text-base', desc: 'text-xs' },
  md: { container: 'py-12', emoji: 'text-5xl', title: 'text-lg', desc: 'text-sm' },
  lg: { container: 'py-16', emoji: 'text-6xl', title: 'text-xl', desc: 'text-sm' },
}
const s = sizes[size]
---

<div class={`text-center ${s.container} ${classes}`}>
  {emoji && (
    <div class={`${s.emoji} mb-3 opacity-60`} aria-hidden="true">
      {emoji}
    </div>
  )}
  <h3 class={`font-display font-semibold ${s.title} text-[var(--color-text)]`}>
    {title}
  </h3>
  {description && (
    <p class={`mt-1.5 ${s.desc} text-[var(--color-text-muted)] max-w-md mx-auto`}>
      {description}
    </p>
  )}
  <div class="mt-4">
    <slot name="cta" />
  </div>
</div>
