---
/**
 * CategoryPage — Bir kategori için listeleme sayfası (paylaşımlı şablon).
 * 4 kategori sayfası (ekran-koruyucu, parfum, kimya, canta) bunu kullanır.
 */
import Base from '@layouts/Base.astro'
import ProductCard from './ProductCard.tsx'
import { getProductsByCategory, CATEGORY_META, type SimpleCategory } from '@lib/catalog-extra'

type Props = {
  category: SimpleCategory
}

const { category } = Astro.props as Props
const meta = CATEGORY_META[category]
const products = getProductsByCategory(category)

const breadcrumbs = [
  { label: 'Ana Sayfa', href: '/' },
  { label: 'Ürünler', href: '/urunler' },
  { label: meta.name, href: meta.href },
]
---

<Base
  title={`${meta.name} — Carmat`}
  description={meta.description}
>
  <section class="container-page py-10 md:py-16">
    {/* Breadcrumb */}
    <nav class="mb-6 flex items-center gap-1.5 text-xs text-[var(--color-text-muted)]" aria-label="breadcrumb">
      {breadcrumbs.map((b, i) => (
        <>
          {i > 0 && <span class="text-[var(--color-text-muted)]/50">/</span>}
          {i === breadcrumbs.length - 1 ? (
            <span class="text-[var(--color-text)]">{b.label}</span>
          ) : (
            <a href={b.href} class="hover:text-[var(--color-primary)] transition-colors">{b.label}</a>
          )}
        </>
      ))}
    </nav>

    {/* Header */}
    <header class="max-w-3xl mb-10">
      <div class="flex items-center gap-3">
        <span class="text-4xl">{meta.emoji}</span>
        <p class="text-sm text-[var(--color-primary)] font-medium uppercase tracking-wider">Kategori</p>
      </div>
      <h1 class="mt-3 font-display text-3xl md:text-4xl font-semibold tracking-tight">
        {meta.name}
      </h1>
      <p class="mt-3 text-[var(--color-text-soft)] leading-relaxed">
        {meta.description}
      </p>
      <p class="mt-2 text-sm text-[var(--color-text-muted)]">
        {products.length} ürün
      </p>
    </header>

    {/* Grid */}
    {products.length > 0 ? (
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
        {products.map((p) => (
          <ProductCard product={p} />
        ))}
      </div>
    ) : (
      <div class="text-center py-20 text-[var(--color-text-muted)]">
        Bu kategoride henüz ürün yok.
      </div>
    )}
  </section>
</Base>
