---
/**
 * MobileDrawer — Mobil için sol açılır menü (hamburger).
 * MobileBottomNav yerine geçer. md+ ekranlarda görünmez.
 *
 * Header'daki üst bar'a hamburger butonu ekleyip bu drawer'ı tetikler.
 */
const path = Astro.url.pathname

type NavItem = { href: string; label: string; icon: string; activeWhen: (p: string) => boolean }

const PRIMARY: NavItem[] = [
  { href: '/', label: 'Anasayfa', icon: 'M3 12l9-9 9 9M5 10v10h4v-6h6v6h4V10', activeWhen: (p) => p === '/' },
  { href: '/konfigurator', label: 'Paspas Tasarla', icon: 'M12 4v16m8-8H4M19.07 4.93l-2.12 2.12m-9.9 9.9-2.12 2.12m0-14.14 2.12 2.12m9.9 9.9 2.12 2.12', activeWhen: (p) => p.startsWith('/konfigurator') },
  { href: '/urunler', label: 'Tüm Ürünler', icon: 'M3 3h18v6H3zM3 13h18v8H3z', activeWhen: (p) => p.startsWith('/urunler') },
  { href: '/markalar', label: 'Markalar', icon: 'M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z', activeWhen: (p) => p.startsWith('/markalar') },
]

const SECONDARY: NavItem[] = [
  { href: '/sepet', label: 'Sepetim', icon: 'M3 3h2l2 12h12l2-8H6M7 21a2 2 0 1 1 0-4 2 2 0 0 1 0 4zm10 0a2 2 0 1 1 0-4 2 2 0 0 1 0 4z', activeWhen: (p) => p.startsWith('/sepet') },
  { href: '/siparis-takip', label: 'Sipariş Takip', icon: 'M16 11V7a4 4 0 0 0-8 0v4M5 9h14l1 12H4z', activeWhen: (p) => p.startsWith('/siparis-takip') },
  { href: '/galeri', label: 'Galeri', icon: 'M21 15V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14M21 15l-5-5L5 21M16 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4', activeWhen: (p) => p.startsWith('/galeri') },
  { href: '/blog', label: 'Blog', icon: 'M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2zM14 3v6h6M16 13H8M16 17H8M10 9H8', activeWhen: (p) => p.startsWith('/blog') },
]

const TERTIARY: NavItem[] = [
  { href: '/hakkimizda', label: 'Hakkımızda', icon: 'M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10zM12 8v4M12 16h.01', activeWhen: (p) => p.startsWith('/hakkimizda') },
  { href: '/sss', label: 'Sıkça Sorulanlar', icon: 'M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3M12 17h.01M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z', activeWhen: (p) => p.startsWith('/sss') },
  { href: '/iletisim', label: 'İletişim', icon: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72a2 2 0 0 1 1.72 2z', activeWhen: (p) => p.startsWith('/iletisim') },
  { href: '/yasal', label: 'Yasal', icon: 'M9 12l2 2 4-4M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z', activeWhen: (p) => p.startsWith('/yasal') },
]
---

{/* Hamburger toggle button — mobil top bar içine yerleştirilir. Position fixed top-left. */}
<button
  id="mobileDrawerToggle"
  type="button"
  aria-label="Menüyü aç"
  aria-controls="mobileDrawer"
  aria-expanded="false"
  class="md:hidden fixed top-1.5 left-2 z-40 size-9 grid place-items-center rounded-lg hover:bg-[var(--color-surface-2)] active:scale-95 transition-all"
>
  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round">
    <line x1="4" y1="7" x2="20" y2="7" />
    <line x1="4" y1="12" x2="20" y2="12" />
    <line x1="4" y1="17" x2="20" y2="17" />
  </svg>
</button>

{/* Backdrop */}
<div
  id="mobileDrawerBackdrop"
  class="md:hidden fixed inset-0 z-[80] bg-black/70 backdrop-blur-sm hidden"
  data-state="closed"
></div>

{/* Drawer panel — sol kenardan kayar */}
<aside
  id="mobileDrawer"
  class="md:hidden fixed inset-y-0 left-0 z-[81] w-[82%] max-w-[340px] bg-[var(--color-surface)] border-r border-[var(--color-border)]/60 shadow-2xl translate-x-[-110%] transition-transform duration-300 ease-out flex flex-col"
  style="padding-top: env(safe-area-inset-top); padding-bottom: env(safe-area-inset-bottom);"
  aria-hidden="true"
>
  {/* Header */}
  <div class="flex items-center justify-between px-4 py-4 border-b border-[var(--color-border)]/60">
    <a href="/" class="flex items-center gap-2">
      <img src="/logo.png" alt="Carmat" class="h-8 w-auto" />
    </a>
    <button
      id="mobileDrawerClose"
      type="button"
      aria-label="Menüyü kapat"
      class="size-9 grid place-items-center rounded-lg hover:bg-[var(--color-surface-2)]"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
        <path d="M18 6 6 18M6 6l12 12" />
      </svg>
    </button>
  </div>

  {/* Primary CTA */}
  <div class="px-4 pt-4 pb-2">
    <a
      href="/konfigurator"
      class="flex items-center justify-center gap-2 w-full py-3.5 rounded-xl bg-[var(--color-primary)] text-black font-bold text-sm shadow-lg"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><path d="M12 4v16m8-8H4" /></svg>
      Paspasını Tasarla
    </a>
  </div>

  {/* Nav groups */}
  <nav class="flex-1 overflow-y-auto px-2 py-3 text-sm" aria-label="Mobil menü">
    {[PRIMARY, SECONDARY, TERTIARY].map((group, gi) => (
      <ul class={gi > 0 ? 'mt-3 pt-3 border-t border-[var(--color-border)]/40' : ''}>
        {group.map((it) => {
          const active = it.activeWhen(path)
          return (
            <li>
              <a
                href={it.href}
                aria-current={active ? 'page' : undefined}
                class={[
                  'flex items-center gap-3 px-3 py-3 rounded-xl min-h-[48px] transition-colors',
                  active
                    ? 'bg-[var(--color-primary-soft)]/40 text-[var(--color-primary)] font-semibold'
                    : 'text-[var(--color-text-soft)] hover:bg-[var(--color-surface-2)] hover:text-[var(--color-text)]',
                ].join(' ')}
              >
                <span class="size-8 grid place-items-center rounded-lg bg-[var(--color-surface-2)] shrink-0">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d={it.icon} />
                  </svg>
                </span>
                <span class="text-[15px]">{it.label}</span>
              </a>
            </li>
          )
        })}
      </ul>
    ))}
  </nav>

  {/* Footer — WhatsApp + telefon */}
  <div class="px-4 py-3 border-t border-[var(--color-border)]/60 space-y-2">
    <a
      href="https://wa.me/905447108115"
      target="_blank"
      rel="noopener"
      class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-300 transition-colors"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.296-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413"/></svg>
      <span class="text-sm font-semibold">WhatsApp</span>
    </a>
    <a
      href="tel:+905447108115"
      class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-[var(--color-surface-2)] hover:bg-[var(--color-border)] text-[var(--color-text-soft)] transition-colors"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72a2 2 0 0 1 1.72 2z" /></svg>
      <span class="text-sm font-semibold">+90 544 710 81 15</span>
    </a>
  </div>
</aside>

<script is:inline>
  (function () {
    var toggle = document.getElementById('mobileDrawerToggle')
    var close = document.getElementById('mobileDrawerClose')
    var backdrop = document.getElementById('mobileDrawerBackdrop')
    var drawer = document.getElementById('mobileDrawer')
    if (!toggle || !drawer || !backdrop || !close) return
    function open() {
      backdrop.classList.remove('hidden')
      drawer.classList.remove('-translate-x-full', 'translate-x-[-110%]')
      drawer.style.transform = 'translateX(0)'
      drawer.setAttribute('aria-hidden', 'false')
      toggle.setAttribute('aria-expanded', 'true')
      document.body.style.overflow = 'hidden'
    }
    function shut() {
      drawer.style.transform = ''
      drawer.classList.add('-translate-x-full')
      drawer.setAttribute('aria-hidden', 'true')
      toggle.setAttribute('aria-expanded', 'false')
      setTimeout(function () { backdrop.classList.add('hidden') }, 300)
      document.body.style.overflow = ''
    }
    toggle.addEventListener('click', open)
    close.addEventListener('click', shut)
    backdrop.addEventListener('click', shut)
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') shut()
    })
    // Sayfa değişimde otomatik kapan (Astro client nav)
    document.addEventListener('astro:after-swap', shut)
  })()
</script>
