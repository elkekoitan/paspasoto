---
/**
 * Mobile bottom navigation — müşteri tarafı.
 * Native iOS/Android tarzı tab bar. md+ ekranlarda gizli (top header gösterilir).
 */
const path = Astro.url.pathname

type Item = { href: string; label: string; icon: string; activeWhen: (p: string) => boolean }

const ITEMS: Item[] = [
  {
    href: '/',
    label: 'Anasayfa',
    icon: 'M3 12l9-9 9 9M5 10v10h4v-6h6v6h4V10',
    activeWhen: (p) => p === '/',
  },
  {
    href: '/konfigurator',
    label: 'Tasarla',
    icon: 'M12 4v16m8-8H4M19.07 4.93l-2.12 2.12m-9.9 9.9-2.12 2.12m0-14.14 2.12 2.12m9.9 9.9 2.12 2.12',
    activeWhen: (p) => p.startsWith('/konfigurator'),
  },
  {
    href: '/galeri',
    label: 'Galeri',
    icon: 'M21 15V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14M21 15l-5-5L5 21M16 8a2 2 0 1 0 0-4 2 2 0 0 0 0 4',
    activeWhen: (p) => p.startsWith('/galeri'),
  },
  {
    href: '/siparis-takip',
    label: 'Takip',
    icon: 'M16 11V7a4 4 0 0 0-8 0v4M5 9h14l1 12H4z',
    activeWhen: (p) => p.startsWith('/siparis-takip'),
  },
  {
    href: '/iletisim',
    label: 'İletişim',
    icon: 'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72a2 2 0 0 1 1.72 2z',
    activeWhen: (p) => p.startsWith('/iletisim') || p.startsWith('/hakkimizda') || p.startsWith('/sss') || p.startsWith('/markalar') || p.startsWith('/tanitim'),
  },
]
---

<nav
  class="md:hidden fixed bottom-0 left-0 right-0 z-50 bg-[var(--color-surface)]/95 backdrop-blur-lg border-t border-[var(--color-border)]/60"
  style="padding-bottom: env(safe-area-inset-bottom);"
  aria-label="Mobil navigasyon"
>
  <div class="grid grid-cols-5 gap-1 px-2 pt-2 pb-1">
    {
      ITEMS.map((it) => {
        const active = it.activeWhen(path)
        return (
          <a
            href={it.href}
            class={[
              'flex flex-col items-center justify-center gap-0.5 py-1.5 rounded-xl transition-colors',
              active
                ? 'text-[var(--color-primary)]'
                : 'text-[var(--color-text-muted)] active:bg-[var(--color-surface-2)] hover:text-[var(--color-text-soft)]',
            ].join(' ')}
            aria-current={active ? 'page' : undefined}
          >
            <span class={['size-9 grid place-items-center rounded-xl transition-all', active ? 'bg-[var(--color-primary-soft)]' : ''].join(' ')}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d={it.icon} />
              </svg>
            </span>
            <span class={['text-[10px] font-semibold tracking-tight', active ? 'opacity-100' : 'opacity-90'].join(' ')}>{it.label}</span>
          </a>
        )
      })
    }
  </div>
</nav>
