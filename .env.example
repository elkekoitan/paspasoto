# =========================================
# CMS (Strapi)
# =========================================

# Sunucu
HOST=0.0.0.0
PORT=1337
NODE_ENV=development

# Lokal dev'de SQLite kullanılıyor; production için Postgres'e geçilir.
# DATABASE_CLIENT seçenekleri: sqlite | postgres
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Production (Coolify)
# DATABASE_CLIENT=postgres
# DATABASE_HOST=db-postgres
# DATABASE_PORT=5432
# DATABASE_NAME=paspasoto
# DATABASE_USERNAME=paspasoto
# DATABASE_PASSWORD=
# DATABASE_SSL=false

# Strapi secrets — production'da uzun rastgele üretin
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=dev-api-token-salt
ADMIN_JWT_SECRET=dev-admin-jwt-secret
TRANSFER_TOKEN_SALT=dev-transfer-token-salt
JWT_SECRET=dev-jwt-secret

# S3 / MinIO (production'da kullanılır, lokal'de boş bırakılabilir → local upload)
# S3_ENDPOINT=http://storage-minio:9000
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=paspasoto-media
# S3_REGION=us-east-1
# S3_PUBLIC_URL=https://media.paspasoto.com

# E-posta (production'da)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
SMTP_FROM=PaspasOto <siparis@paspasoto.com>
SMTP_REPLY_TO=destek@paspasoto.com

# Admin bildirim e-postaları (virgülle)
ADMIN_NOTIFICATION_EMAILS=turhanhamza@gmail.com

# Public URL'ler (production'da)
PUBLIC_URL=http://localhost:1337
WEB_PUBLIC_URL=http://localhost:4321

# =========================================
# WEB (Astro)
# =========================================

PUBLIC_STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=
STRAPI_INTERNAL_TOKEN=
PUBLIC_SITE_URL=http://localhost:4321
PUBLIC_PLAUSIBLE_DOMAIN=
SENTRY_DSN=
